<script>
  function checkWASAR() {
    const input = (document.getElementById('wasa-r-input') as HTMLInputElement);
    const err = document.getElementById('wasa-r-error');
    const val = input.value.trim();
    if (val.length !== 8) {
      err!.style.display = 'block';
      err!.textContent = 'Please enter your valid 8-digit C-Code.';
      return;
    }
    err!.style.display = 'none';
    window.open(`https://wasarwp.gop.pk/CustomerServices/DuplicateBill?ccode=${val}`, '_blank');
  }
</script>
