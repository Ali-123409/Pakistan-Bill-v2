---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://pakistanbill.online/gas/#webpage",
    "url": "https://pakistanbill.online/gas/",
    "name": "Gas Bill Checker Pakistan — SNGPL & SSGC Bill Online 2026",
    "description": "Check SNGPL and SSGC gas bills online. SNGPL covers Punjab, KPK, ICT. SSGC covers Sindh and Balochistan. Free, instant, no login required.",
    "isPartOf": {"@id": "https://pakistanbill.online/#website"},
    "dateModified": "2026-03-11"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"Home","item":"https://pakistanbill.online/"},
      {"@type":"ListItem","position":2,"name":"Gas Bills","item":"https://pakistanbill.online/gas/"}
    ]
  }
];
---
<BaseLayout
  title="Gas Bill Checker Pakistan — SNGPL & SSGC Bill Online 2026"
  description="Check SNGPL and SSGC gas bills online. SNGPL covers Punjab, KPK, ICT. SSGC covers Sindh and Balochistan. Free, instant, no login required."
  canonical="/gas/"
  schema={schema}
  lastmod="2026-03-11"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium">Gas Bills</span>
      </nav>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-3">Gas Bill Checker Pakistan — SNGPL & SSGC</h1>
    <p class="text-lg text-neutral-600 mb-8">Check SNGPL and SSGC gas bills online. SNGPL covers Punjab, KPK, ICT. SSGC covers Sindh and Balochistan. Free, instant, no login required.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
      
      <a href="/sngpl-bill/" class="bg-white border-2 border-neutral-200 rounded-2xl p-5 hover:border-primary-400 hover:shadow-md transition-all group">
        <div class="text-3xl mb-3">🔥</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">SNGPL Gas</h2>
        <p class="text-xs text-neutral-400 font-medium uppercase tracking-wide mb-2">Punjab & KPK</p>
        <p class="text-sm text-neutral-500 mb-3">Punjab, KPK, Islamabad/ICT, AJK — 11-digit consumer number</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check SNGPL Gas Bill →</span>
      </a>
      <a href="/ssgc-bill/" class="bg-white border-2 border-neutral-200 rounded-2xl p-5 hover:border-primary-400 hover:shadow-md transition-all group">
        <div class="text-3xl mb-3">🔥</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">SSGC Gas</h2>
        <p class="text-xs text-neutral-400 font-medium uppercase tracking-wide mb-2">Sindh & Balochistan</p>
        <p class="text-sm text-neutral-500 mb-3">Sindh and Balochistan — 10-digit consumer number</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check SSGC Gas Bill →</span>
      </a>
    </div>

    <div class="bg-primary-50 border border-primary-200 rounded-2xl p-5 mb-8">
      <h2 class="font-bold text-primary-800 mb-2">⚡ Check Any Bill Without Switching Pages</h2>
      <p class="text-sm text-primary-700 mb-3">Use our universal dashboard — toggle between all 19 utility providers instantly.</p>
      <a href="/dashboard/" class="inline-block bg-primary-700 text-white px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-primary-800 transition-colors">Open Bill Dashboard →</a>
    </div>

    <div class="border-t border-neutral-200 pt-6">
      <h2 class="font-bold text-neutral-800 text-sm mb-3 uppercase tracking-wider">All Utility Bill Silos</h2>
      <div class="flex flex-wrap gap-3">
        <a href="/electricity/" class="font-semibold text-sm bg-yellow-50 border border-yellow-200 rounded-lg px-4 py-2 text-yellow-800 hover:bg-yellow-100">⚡ Electricity Bills</a>
        <a href="/gas/" class="font-semibold text-sm bg-orange-50 border border-orange-200 rounded-lg px-4 py-2 text-orange-800 hover:bg-orange-100">🔥 Gas Bills</a>
        <a href="/telecom/" class="font-semibold text-sm bg-blue-50 border border-blue-200 rounded-lg px-4 py-2 text-blue-800 hover:bg-blue-100">📞 Telecom Bills</a>
        <a href="/water/" class="font-semibold text-sm bg-cyan-50 border border-cyan-200 rounded-lg px-4 py-2 text-cyan-800 hover:bg-cyan-100">💧 Water Bills</a>
      </div>
    </div>
  </div>

<p style="margin:1rem 0;line-height:1.8;">PakistanBill.online is <strong>Pakistan's only platform</strong> covering <em>all</em> utility categories. Beyond gas, we cover all 13 electricity DISCOs — <a href="/lesco-bill/">LESCO</a>, <a href="/mepco-bill/">MEPCO</a>, <a href="/gepco-bill/">GEPCO</a>, <a href="/fesco-bill/">FESCO</a>, <a href="/iesco-bill/">IESCO</a>, <a href="/k-electric-bill/">K-Electric</a> and more — plus <a href="/ptcl-bill/">PTCL</a> and <a href="/water/">WASA water bills</a>. Open the <a href="/dashboard/">universal bill dashboard</a> to check all providers at once.</p>

  <section style="max-width:900px;margin:2rem auto;padding:0 1rem;">
    <h2 style="font-size:1.1rem;font-weight:700;color:#1e293b;margin-bottom:1rem;">Pakistan Gas Bill Checker — SNGPL & SSGC</h2>
    <p style="color:#555;line-height:1.8;margin-bottom:1rem;">Pakistan has two gas distribution companies covering the entire country. <a href="/sngpl-bill/" style="color:#01411C;font-weight:600;">SNGPL (Sui Northern Gas Pipelines Limited)</a> supplies gas to Punjab, Khyber Pakhtunkhwa, Islamabad Capital Territory, and Azad Kashmir. <a href="/ssgc-bill/" style="color:#01411C;font-weight:600;">SSGC (Sui Southern Gas Company)</a> supplies gas to Sindh and Balochistan including Karachi, Hyderabad, Quetta, and Gwadar.</p>
    <p style="color:#555;line-height:1.8;margin-bottom:1rem;">To check your gas bill online, you need your consumer number printed on your gas bill. SNGPL consumer numbers are 11 digits. SSGC consumer numbers are 10 digits. Enter your consumer number in the checker above to view your current bill, amount payable, and due date — free, no login required.</p>
    <p style="color:#555;line-height:1.8;">PakistanBill.online is <strong>Pakistan's only platform</strong> covering both gas utilities alongside all 13 electricity DISCOs, <a href="/ptcl-bill/" style="color:#01411C;">PTCL telecom</a>, and <a href="/water/" style="color:#01411C;">WASA water bills</a>. Check any bill from the <a href="/dashboard/" style="color:#01411C;">universal bill dashboard</a>.</p>
  </section>
</BaseLayout>
