<script>
  function checkWASAF() {
    const input = (document.getElementById('wasa-f-input') as HTMLInputElement);
    const err = document.getElementById('wasa-f-error');
    const val = input.value.trim();
    if (!val) {
      err!.style.display = 'block';
      err!.textContent = 'Please enter your FWASA account number.';
      return;
    }
    err!.style.display = 'none';
    window.open(`https://fwasa.com.pk/billinquiry?account=${val}`, '_blank');
  }
</script>
