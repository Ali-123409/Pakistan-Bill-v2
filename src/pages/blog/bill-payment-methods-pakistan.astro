---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": "https://pakistanbill.online/blog/bill-payment-methods-pakistan/#article",
    "headline": "How to Pay Electricity Bill Online in Pakistan 2026",
    "description": "Pay electricity bill online in Pakistan via JazzCash, EasyPaisa, HBL, MCB, Meezan Bank. Step-by-step guide for LESCO, MEPCO, K-Electric, SNGPL, PTCL bills.",
    "datePublished": "2026-03-13", "dateModified": "2026-03-13",
    "author": {"@type":"Organization","name":"PakistanBill","@id":"https://pakistanbill.online/#organization"},
    "publisher": {"@id":"https://pakistanbill.online/#organization"}
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"How to pay LESCO bill online?","acceptedAnswer":{"@type":"Answer","text":"Pay LESCO bill through JazzCash (select Utility Bills → Electricity → LESCO → enter 14-digit reference number), EasyPaisa (same process), or any bank mobile app like HBL Mobile, MCB, or Meezan Bank."}},
      {"@type":"Question","name":"Which apps can I use to pay electricity bill in Pakistan?","acceptedAnswer":{"@type":"Answer","text":"JazzCash, EasyPaisa, HBL Mobile Banking, MCB Mobile, Meezan Bank App, UBL Digital, Askari Bank App, Bank Alfalah. All support LESCO, MEPCO, GEPCO, FESCO, IESCO, K-Electric, SNGPL, SSGC, and PTCL payments."}},
      {"@type":"Question","name":"Can I pay electricity bill at ATM?","acceptedAnswer":{"@type":"Answer","text":"Yes. HBL, MCB, UBL, and most major bank ATMs in Pakistan support utility bill payments. Select Bill Payment on the ATM menu, choose your DISCO, enter your reference number, and confirm."}}
    ]
  },
  {
    "@context":"https://schema.org","@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Home","item":"https://pakistanbill.online/"},
      {"@type":"ListItem","position":2,"name":"Blog","item":"https://pakistanbill.online/blog/"},
      {"@type":"ListItem","position":3,"name":"How to Pay Electricity Bill Online in Pakistan 2026","item":"https://pakistanbill.online/blog/bill-payment-methods-pakistan/"}
    ]
  }
];
---
<BaseLayout
  title="How to Pay Electricity Bill Online in Pakistan 2026"
  description="Pay electricity bill online in Pakistan via JazzCash, EasyPaisa, HBL, MCB, Meezan Bank. Step-by-step guide for LESCO, MEPCO, K-Electric, SNGPL, PTCL bills."
  canonical="/blog/bill-payment-methods-pakistan/"
  schema={schema}
  lastmod="2026-03-13"
  pageType="article"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/blog/" class="hover:text-primary-600">Blog</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium truncate">How to Pay Electricity Bill Online in Pa...</span>
      </nav>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6">
      <span class="text-xs font-semibold text-primary-600 bg-primary-50 px-3 py-1 rounded-full">Guides</span>
      <span class="text-xs text-neutral-400 ml-3">Updated March 2026</span>
    </div>
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-4">How to Pay Electricity Bill Online in Pakistan — All Methods</h1>
    <p class="text-neutral-600 mb-8 text-lg leading-relaxed">Pakistan now offers multiple ways to pay utility bills online — from mobile wallets to bank apps. This guide covers every payment method for electricity, gas, water, and PTCL bills with step-by-step instructions.</p>

    <h2 class="text-2xl font-heading font-bold mt-8 mb-4">Frequently Asked Questions</h2>
    <div class="space-y-3 mb-10">
      <details class="faq-item"><summary class="faq-question">How to pay LESCO bill online?</summary><div class="px-4 pb-4 text-sm text-neutral-600">Pay LESCO bill through JazzCash (select Utility Bills → Electricity → LESCO → enter 14-digit reference number), EasyPaisa (same process), or any bank mobile app like HBL Mobile, MCB, or Meezan Bank.</div></details>
      <details class="faq-item"><summary class="faq-question">Which apps can I use to pay electricity bill in Pakistan?</summary><div class="px-4 pb-4 text-sm text-neutral-600">JazzCash, EasyPaisa, HBL Mobile Banking, MCB Mobile, Meezan Bank App, UBL Digital, Askari Bank App, Bank Alfalah. All support LESCO, MEPCO, GEPCO, FESCO, IESCO, K-Electric, SNGPL, SSGC, and PTCL payments.</div></details>
      <details class="faq-item"><summary class="faq-question">Can I pay electricity bill at ATM?</summary><div class="px-4 pb-4 text-sm text-neutral-600">Yes. HBL, MCB, UBL, and most major bank ATMs in Pakistan support utility bill payments. Select Bill Payment on the ATM menu, choose your DISCO, enter your reference number, and confirm.</div></details>
    </div>

    <div class="border-t border-neutral-200 pt-6">
      <h2 class="font-bold text-neutral-800 mb-4">Related Pages</h2>
      <div class="flex flex-wrap gap-2">
        <a href="/lesco-bill/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-primary-600 hover:underline font-medium">LESCO Bill →</a>
        <a href="/sngpl-bill/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-primary-600 hover:underline font-medium">SNGPL Gas Bill →</a>
