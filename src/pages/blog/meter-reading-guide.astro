import BaseLayout from '../../layouts/BaseLayout.astro';
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": "https://pakistanbill.online/blog/meter-reading-guide/#article",
    "headline": "How to Read Electric Meter in Pakistan — Complete Guide 2026",
    "description": "How to read your electricity meter in Pakistan. Digital vs analog meter reading guide. Understand units, peak hours, and how meter reading affects your bill.",
    "datePublished": "2026-03-13", "dateModified": "2026-03-13",
    "author": {"@type":"Organization","name":"PakistanBill","@id":"https://pakistanbill.online/#organization"},
    "publisher": {"@id":"https://pakistanbill.online/#organization"}
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"How to read a digital electricity meter in Pakistan?","acceptedAnswer":{"@type":"Answer","text":"A digital meter shows units consumed as a number (e.g., 1234 kWh). Note the reading at the start and end of the month. The difference is your consumption. DISCO meter readers record this number when they visit monthly."}},
      {"@type":"Question","name":"How to read an analog electricity meter?","acceptedAnswer":{"@type":"Answer","text":"Read the dials from right to left. Each dial moves when the one to its right completes a full rotation. If a pointer is between two numbers, record the lower number. Ignore the last red dial. Subtract previous reading from current to get units consumed."}},
      {"@type":"Question","name":"Why is my meter reading different from my bill?","acceptedAnswer":{"@type":"Answer","text":"If your meter reading differs from your bill, it may be an estimated bill (DISCO estimated your consumption instead of physically reading the meter). You can contest estimated bills by calling DISCO helpline 118 and providing your actual meter photo."}}
    ]
  },
  {
    "@context":"https://schema.org","@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Home","item":"https://pakistanbill.online/"},
      {"@type":"ListItem","position":2,"name":"Blog","item":"https://pakistanbill.online/blog/"},
      {"@type":"ListItem","position":3,"name":"How to Read Electric Meter in Pakistan — Complete Guide 2026","item":"https://pakistanbill.online/blog/meter-reading-guide/"}
    ]
  }
];
