---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": "https://pakistanbill.online/blog/lesco-new-connection/#article",
    "headline": "LESCO New Connection — How to Apply Online 2026",
    "description": "How to apply for LESCO new electricity connection in Lahore. Documents needed, process, fees, and timeline. LESCO online application guide 2026.",
    "datePublished": "2026-03-13", "dateModified": "2026-03-13",
    "author": {"@type":"Organization","name":"PakistanBill","@id":"https://pakistanbill.online/#organization"},
    "publisher": {"@id":"https://pakistanbill.online/#organization"}
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"How to apply for LESCO new connection?","acceptedAnswer":{"@type":"Answer","text":"Apply for LESCO new connection at lesco.gov.pk or visit any LESCO sub-division office. Required documents: CNIC copy, ownership documents (ownership deed or rent agreement), site plan, and neighbor's electricity bill. Processing takes 15-30 working days."}},
      {"@type":"Question","name":"What are LESCO new connection fees?","acceptedAnswer":{"@type":"Answer","text":"LESCO new connection fees vary by load: For 5KW domestic connection, security deposit is approximately Rs 15,000-25,000 plus service charges. Fees depend on distance from transformer and required cable length. Get exact quote from your local LESCO sub-division."}},
      {"@type":"Question","name":"LESCO connection helpline?","acceptedAnswer":{"@type":"Answer","text":"Call LESCO helpline 118 or 042-111-000-118 for new connection queries in Lahore. You can also email at info@lesco.gov.pk or visit the LESCO headquarters at 1-Gulberg III, Lahore for in-person assistance."}}
    ]
  },
  {
    "@context":"https://schema.org","@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Home","item":"https://pakistanbill.online/"},
      {"@type":"ListItem","position":2,"name":"Blog","item":"https://pakistanbill.online/blog/"},
      {"@type":"ListItem","position":3,"name":"LESCO New Connection — How to Apply Online 2026","item":"https://pakistanbill.online/blog/lesco-new-connection/"}
    ]
  }
];
---
<BaseLayout
  title="LESCO New Connection — How to Apply Online 2026"
  description="How to apply for LESCO new electricity connection in Lahore. Documents needed, process, fees, and timeline. LESCO online application guide 2026."
  canonical="/blog/lesco-new-connection/"
  schema={schema}
  lastmod="2026-03-13"
  pageType="article"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/blog/" class="hover:text-primary-600">Blog</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium">LESCO</span>
      </nav>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-4">
      <span class="text-xs font-semibold text-primary-600 bg-primary-50 px-3 py-1 rounded-full">Guides</span>
      <span class="text-xs text-neutral-400 ml-3">Updated March 2026</span>
    </div>
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-4">LESCO New Connection — How to Apply Online 2026</h1>

    <h2 class="text-xl font-heading font-bold text-neutral-900 mt-8 mb-4">Frequently Asked Questions</h2>
    <div class="space-y-3 mb-10">
      <details class="faq-item"><summary class="faq-question">How to apply for LESCO new connection?</summary><div class="px-4 pb-4 text-sm text-neutral-600">Apply for LESCO new connection at lesco.gov.pk or visit any LESCO sub-division office. Required documents: CNIC copy, ownership documents (ownership deed or rent agreement), site plan, and neighbor's electricity bill. Processing takes 15-30 working days.</div></details>
      <details class="faq-item"><summary class="faq-question">What are LESCO new connection fees?</summary><div class="px-4 pb-4 text-sm text-neutral-600">LESCO new connection fees vary by load: For 5KW domestic connection, security deposit is approximately Rs 15,000-25,000 plus service charges. Fees depend on distance from transformer and required cable length. Get exact quote from your local LESCO sub-division.</div></details>
      <details class="faq-item"><summary class="faq-question">LESCO connection helpline?</summary><div class="px-4 pb-4 text-sm text-neutral-600">Call LESCO helpline 118 or 042-111-000-118 for new connection queries in Lahore. You can also email at info@lesco.gov.pk or visit the LESCO headquarters at 1-Gulberg III, Lahore for in-person assistance.</div></details>
    </div>

    <div class="bg-primary-50 border border-primary-200 rounded-2xl p-6 mb-8 text-center">
      <h2 class="font-bold text-xl text-primary-900 mb-2">Check Your LESCO Bill Now</h2>
      <p class="text-primary-700 mb-4 text-sm">Free, instant, no login required.</p>
      <a href="/lesco-bill/" class="inline-block bg-primary-700 text-white px-8 py-3 rounded-xl font-bold text-lg hover:bg-primary-800 transition-colors">
        Open LESCO Bill Checker &rarr;
      </a>
    </div>

    <div class="border-t border-neutral-200 pt-6">
      <div class="flex flex-wrap gap-2">
        <a href="/lesco-bill/" class="text-sm bg-primary-50 border border-primary-200 rounded-lg px-3 py-2 text-primary-700 font-semibold hover:underline">LESCO Checker &rarr;</a>
        <a href="/electricity/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">All Electricity Bills &rarr;</a>
        <a href="/electricity-bill-calculator/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">Bill Calculator &rarr;</a>
        <a href="/blog/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">More Guides &rarr;</a>
      </div>
    </div>
  </div>
</BaseLayout>
