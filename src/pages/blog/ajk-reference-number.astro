---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": "https://pakistanbill.online/blog/ajk-reference-number/#article",
    "headline": "AJK WAPDA Reference Number — Find It on Your Bill",
    "description": "Find your AJK WAPDA 14-digit reference number on your electricity bill. Check AJK electricity bill for Muzaffarabad, Mirpur, Rawalakot instantly.",
    "datePublished": "2026-03-13", "dateModified": "2026-03-13",
    "author": {"@type":"Organization","name":"PakistanBill","@id":"https://pakistanbill.online/#organization"},
    "publisher": {"@id":"https://pakistanbill.online/#organization"}
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"Where is AJK WAPDA reference number on bill?","acceptedAnswer":{"@type":"Answer","text":"The AJK electricity reference number is at the top-right of your bill, labeled Ref. No. It is a 14-digit number above the barcode. AJK WAPDA covers Muzaffarabad, Mirpur, Rawalakot, Kotli, Bagh, and Neelum Valley."}},
      {"@type":"Question","name":"AJK WAPDA reference number format?","acceptedAnswer":{"@type":"Answer","text":"The AJK reference number is always 14 digits — no letters or dashes. Same every month. Used for online bill checking at pakistanbill.online/ajk-bill/ and for payments through JazzCash, EasyPaisa, or bank apps."}},
      {"@type":"Question","name":"AJK WAPDA helpline?","acceptedAnswer":{"@type":"Answer","text":"Call AJK WAPDA helpline 05822-920201 or 118. AJK WAPDA head office is in Muzaffarabad. For billing issues in Mirpur, Kotli, or Rawalakot, contact the respective sub-division office."}}
    ]
  },
  {
    "@context":"https://schema.org","@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Home","item":"https://pakistanbill.online/"},
      {"@type":"ListItem","position":2,"name":"Blog","item":"https://pakistanbill.online/blog/"},
      {"@type":"ListItem","position":3,"name":"AJK WAPDA Reference Number — Find It on Your Bill","item":"https://pakistanbill.online/blog/ajk-reference-number/"}
    ]
  }
];
---
<BaseLayout
  title="AJK WAPDA Reference Number — Find It on Your Bill"
  description="Find your AJK WAPDA 14-digit reference number on your electricity bill. Check AJK electricity bill for Muzaffarabad, Mirpur, Rawalakot instantly."
  canonical="/blog/ajk-reference-number/"
  schema={schema}
  lastmod="2026-03-13"
  pageType="article"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/blog/" class="hover:text-primary-600">Blog</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium">AJK WAPDA</span>
      </nav>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-4">
      <span class="text-xs font-semibold text-primary-600 bg-primary-50 px-3 py-1 rounded-full">Guides</span>
      <span class="text-xs text-neutral-400 ml-3">Updated March 2026</span>
    </div>
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-4">AJK WAPDA Reference Number — Find It on Your Bill</h1>

    <h2 class="text-xl font-heading font-bold text-neutral-900 mt-8 mb-4">Frequently Asked Questions</h2>
    <div class="space-y-3 mb-10">
      <details class="faq-item"><summary class="faq-question">Where is AJK WAPDA reference number on bill?</summary><div class="px-4 pb-4 text-sm text-neutral-600">The AJK electricity reference number is at the top-right of your bill, labeled Ref. No. It is a 14-digit number above the barcode. AJK WAPDA covers Muzaffarabad, Mirpur, Rawalakot, Kotli, Bagh, and Neelum Valley.</div></details>
      <details class="faq-item"><summary class="faq-question">AJK WAPDA reference number format?</summary><div class="px-4 pb-4 text-sm text-neutral-600">The AJK reference number is always 14 digits — no letters or dashes. Same every month. Used for online bill checking at pakistanbill.online/ajk-bill/ and for payments through JazzCash, EasyPaisa, or bank apps.</div></details>
      <details class="faq-item"><summary class="faq-question">AJK WAPDA helpline?</summary><div class="px-4 pb-4 text-sm text-neutral-600">Call AJK WAPDA helpline 05822-920201 or 118. AJK WAPDA head office is in Muzaffarabad. For billing issues in Mirpur, Kotli, or Rawalakot, contact the respective sub-division office.</div></details>
    </div>

    <div class="bg-primary-50 border border-primary-200 rounded-2xl p-6 mb-8 text-center">
      <h2 class="font-bold text-xl text-primary-900 mb-2">Check Your AJK WAPDA Bill Now</h2>
      <p class="text-primary-700 mb-4 text-sm">Free, instant, no login required.</p>
      <a href="/ajk-bill/" class="inline-block bg-primary-700 text-white px-8 py-3 rounded-xl font-bold text-lg hover:bg-primary-800 transition-colors">
        Open AJK WAPDA Bill Checker &rarr;
      </a>
    </div>

    <div class="border-t border-neutral-200 pt-6">
      <div class="flex flex-wrap gap-2">
        <a href="/ajk-bill/" class="text-sm bg-primary-50 border border-primary-200 rounded-lg px-3 py-2 text-primary-700 font-semibold hover:underline">AJK WAPDA Checker &rarr;</a>
        <a href="/electricity/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">All Electricity Bills &rarr;</a>
        <a href="/electricity-bill-calculator/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">Bill Calculator &rarr;</a>
        <a href="/blog/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">More Guides &rarr;</a>
      </div>
    </div>
  </div>
</BaseLayout>
