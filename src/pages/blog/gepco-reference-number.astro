---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": "https://pakistanbill.online/blog/gepco-reference-number/#article",
    "headline": "How to Find GEPCO Reference Number — Where is it on Your Bill?",
    "description": "Learn exactly where the GEPCO 14-digit reference number is on your GEPCO electricity bill. Step-by-step guide with bill layout explained for Gujranwala consumers.",
    "datePublished": "2026-01-25", "dateModified": "2026-03-12",
    "author": {"@type":"Organization","name":"PakistanBill","@id":"https://pakistanbill.online/#organization"},
    "publisher": {"@id":"https://pakistanbill.online/#organization"}
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"Where is the reference number on GEPCO bill?","acceptedAnswer":{"@type":"Answer","text":"The GEPCO reference number is a 14-digit number printed in bold on the top-right section of your GEPCO electricity bill, labeled 'Ref. No.' or 'Reference No.' above the barcode. It never contains letters — only digits."}},
      {"@type":"Question","name":"What is the GEPCO reference number format?","acceptedAnswer":{"@type":"Answer","text":"The GEPCO reference number is always 14 digits long. No letters, no dashes. Example format: 01234567890123. You need this number to check your GEPCO bill online, pay through any bank app or JazzCash/EasyPaisa."}},
      {"@type":"Question","name":"How to check GEPCO bill without reference number?","acceptedAnswer":{"@type":"Answer","text":"If you don't have your GEPCO reference number, you can use your 10-digit GEPCO Customer ID instead — both work on our bill checker. Alternatively call GEPCO helpline 118 with your CNIC to retrieve your reference number."}},
      {"@type":"Question","name":"Is GEPCO reference number same every month?","acceptedAnswer":{"@type":"Answer","text":"Yes. Your GEPCO reference number stays the same every month for your connection. It only changes if WAPDA reassigns your meter to a different feeder. Your 10-digit Customer ID never changes."}}]
  },
  {
    "@context":"https://schema.org","@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Home","item":"https://pakistanbill.online/"},
      {"@type":"ListItem","position":2,"name":"Blog","item":"https://pakistanbill.online/blog/"},
      {"@type":"ListItem","position":3,"name":"GEPCO Reference Number","item":"https://pakistanbill.online/blog/gepco-reference-number/"}
    ]
  }
];
---
<BaseLayout
  title="GEPCO Reference Number — Where is it on Your Bill?"
  description="Where is the GEPCO reference number on your bill? Top-right section, 14 digits, labeled Ref. No. Find it and check your GEPCO Gujranwala electricity bill instantly."
  canonical="/blog/gepco-reference-number/"
  schema={schema}
  lastmod="2026-03-12"
  pageType="article"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/blog/" class="hover:text-primary-600">Blog</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium">GEPCO Reference Number</span>
      </nav>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6">
      <span class="text-xs font-semibold text-primary-600 bg-primary-50 px-3 py-1 rounded-full">GEPCO Guide</span>
      <span class="text-xs text-neutral-400 ml-3">Updated March 2026</span>
    </div>
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-4">How to Find GEPCO Reference Number — Where is it on Your Bill?</h1>

    <div class="bg-primary-50 border-l-4 border-primary-600 p-4 rounded-lg mb-8">
      <p class="font-semibold text-primary-800">Quick Answer: The GEPCO reference number is a <strong>14-digit number</strong> on the <strong>top-right of your bill</strong> labeled <strong>"Ref. No."</strong> — above the barcode. It contains only digits, no letters.</p>
    </div>

    
  <!-- Contextual Internal Links -->
  <section style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:12px;padding:1.25rem;margin:1.5rem 0;">
    <p style="font-size:0.8rem;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.6rem;">Related Tools & Guides</p>
    <div><a href="https://pakistanbill.online/gepco-bill/" style="display:inline-block;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:0.3rem 0.7rem;font-size:0.8rem;font-weight:600;color:#14532d;margin:0.2rem;text-decoration:none;">check GEPCO bill now</a><a href="https://pakistanbill.online/blog/lesco-reference-number/" style="display:inline-block;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:0.3rem 0.7rem;font-size:0.8rem;font-weight:600;color:#14532d;margin:0.2rem;text-decoration:none;">LESCO reference number</a><a href="https://pakistanbill.online/blog/how-to-find-reference-number/" style="display:inline-block;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:0.3rem 0.7rem;font-size:0.8rem;font-weight:600;color:#14532d;margin:0.2rem;text-decoration:none;">how to find reference number</a><a href="https://pakistanbill.online/gujranwala/" style="display:inline-block;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;padding:0.3rem 0.7rem;font-size:0.8rem;font-weight:600;color:#14532d;margin:0.2rem;text-decoration:none;">Gujranwala utility bills</a></div>
  </section>
  <h2 class="text-2xl font-heading font-bold mt-8 mb-4">Where Exactly is the GEPCO Reference Number?</h2>
    <p class="text-neutral-600 mb-4">On every GEPCO electricity bill, look at the <strong>top section of the page</strong>. On the <strong>right side</strong>, you will find a bold number labeled <strong>"Ref. No."</strong> or <strong>"Reference No."</strong> — this is your 14-digit reference number. It is always printed directly above or next to the barcode on the bill.</p>

    <div class="bg-neutral-900 text-green-400 font-mono rounded-xl p-5 mb-6 text-sm">
      <p class="text-neutral-400 text-xs mb-2">// GEPCO Bill — Top Right Section</p>
      <p>┌─────────────────────────────────┐</p>
      <p>│  GEPCO Electricity Bill           │</p>
      <p>│  Consumer: Muhammad Ali          │</p>
      <p>│  ┌──────────────────────────┐   │</p>
      <p class="text-yellow-300">│  │ <strong>Ref. No: 01234567890123</strong>  │   │ ← Here!</p>
      <p>│  │ Customer ID: 1234567890  │   │</p>
      <p>│  └──────────────────────────┘   │</p>
      <p>│  [████████ BARCODE ████████]    │</p>
      <p>└─────────────────────────────────┘</p>
    </div>

    <h2 class="text-2xl font-heading font-bold mt-8 mb-4">What Does the GEPCO Reference Number Look Like?</h2>
    <ul class="space-y-2 text-neutral-600 mb-6 list-disc list-inside">
      <li>Always exactly <strong>14 digits</strong> — never more, never less</li>
      <li>Only numbers — no letters (A, B, C) or dashes</li>
      <li>Example: <code class="bg-neutral-100 px-2 py-0.5 rounded font-mono">01234567890123</code></li>
      <li>Printed in <strong>bold</strong> near the top of your bill</li>
      <li>Labeled <strong>"Ref. No."</strong> or <strong>"Reference No."</strong></li>
      <li>Stays the same every month (unless feeder reassignment)</li>
    </ul>

    <h2 class="text-2xl font-heading font-bold mt-8 mb-4">Can't Find Your GEPCO Reference Number?</h2>
    <div class="space-y-3 mb-8">
      {[
        ["Check an old bill", "Your reference number never changes. Any previous GEPCO bill will have the same reference number."],
        ["Use your Customer ID instead", "The 10-digit Customer ID also works on our GEPCO bill checker. Click the 'Customer ID' tab."],
        ["Call GEPCO helpline 118", "Provide your name, address, and CNIC. The helpline can give you your reference number immediately."],
        ["Check JazzCash/EasyPaisa payment history", "If you've paid your GEPCO bill online before, your reference number is saved in the payment history."],
        ["Visit your nearest GEPCO office", "Bring your CNIC for identity verification and they will provide your reference number."],
      ].map((item) => (
        <div class="flex gap-3 bg-white border border-neutral-200 rounded-xl p-4">
          <span class="text-primary-600 font-bold text-lg flex-shrink-0">→</span>
          <div><h3 class="font-semibold text-neutral-900 text-sm mb-1">{item[0]}</h3><p class="text-sm text-neutral-500">{item[1]}</p></div>
        </div>
      ))}
    </div>

    <div class="bg-primary-700 text-white rounded-2xl p-6 mb-8 text-center">
      <h2 class="font-bold text-xl mb-2">Found Your GEPCO Reference Number?</h2>
      <p class="text-primary-200 mb-4">Check your GEPCO bill right now — free, instant, no login required.</p>
      <a href="/gepco-bill/" class="inline-block bg-white text-primary-700 px-8 py-3 rounded-xl font-bold hover:bg-primary-50 transition-colors">Check GEPCO Bill Now →</a>
    </div>

    <h2 class="text-2xl font-heading font-bold mt-8 mb-4">Frequently Asked Questions</h2>
    <div class="space-y-3 mb-10">
      {[
        { q: "Where is the reference number on GEPCO bill?", a: "The GEPCO reference number is printed in bold on the top-right section of your bill, labeled 'Ref. No.' or 'Reference No.' — above the barcode. It is always 14 digits, no letters." },
        { q: "What is the GEPCO reference number format?", a: "The GEPCO reference number is always 14 digits. No letters, no dashes. You need this number to check your bill online or pay through JazzCash, EasyPaisa, or any bank app." },
        { q: "How to check GEPCO bill without reference number?", a: "Use your 10-digit Customer ID instead — it also works on our checker. Or call GEPCO helpline 118 with your CNIC to retrieve your reference number." },
        { q: "Is GEPCO reference number same every month?", a: "Yes. Your GEPCO reference number stays the same every month. It only changes if WAPDA reassigns your meter. Your 10-digit Customer ID never changes at all." },
      ].map((faq) => (
        <details class="faq-item">
          <summary class="faq-question">{faq.q}</summary>
          <div class="px-4 pb-4 text-sm text-neutral-600">{faq.a}</div>
        </details>
      ))}
    </div>

    <div class="border-t border-neutral-200 pt-6">
      <h2 class="font-bold text-neutral-800 mb-4">Reference Number Guides for All DISCOs</h2>
      <div class="flex flex-wrap gap-2">
        {["lesco","mepco","gepco","fesco","iesco"].map(d => (
          <a href={`/blog/${d}-reference-number/`} class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-primary-600 hover:underline uppercase font-semibold">{d.toUpperCase()} →</a>
        ))}
        <a href="/blog/how-to-find-reference-number/" class="text-sm bg-primary-50 border border-primary-200 rounded-lg px-3 py-2 text-primary-700 hover:underline font-semibold">All DISCOs Guide →</a>
      </div>
    </div>
  </div>

<p>After finding your GEPCO reference number, check your <a href="/gepco-bill/"><strong>GEPCO bill</strong></a> on PakistanBill.online — <strong>Pakistan's only platform</strong> covering all 19 providers. Also check: <a href="/lesco-bill/">LESCO</a> | <a href="/fesco-bill/">FESCO</a> | <a href="/sngpl-bill/">SNGPL gas</a>. See our <a href="/gujranwala/">Gujranwala utility bills guide</a>.</p>
</BaseLayout>
