    "@type": "Article",
    "@id": "https://pakistanbill.online/blog/gas-bill-consumer-number/#article",
    "headline": "SNGPL & SSGC Consumer Number — Where to Find It on Your Bill",
    "description": "Find your SNGPL or SSGC consumer number on your gas bill. SNGPL: 11-digit number top section. SSGC: 10-digit number. Check gas bill online instantly.",
    "datePublished": "2026-03-13", "dateModified": "2026-03-13",
    "author": {"@type":"Organization","name":"PakistanBill","@id":"https://pakistanbill.online/#organization"},
    "publisher": {"@id":"https://pakistanbill.online/#organization"}
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"Where is the SNGPL consumer number on the bill?","acceptedAnswer":{"@type":"Answer","text":"The SNGPL consumer number is an 11-digit number printed in the top-left or top-center section of your SNGPL gas bill, labeled Consumer No. or Consumer Number. SNGPL covers Punjab, KPK, Islamabad, and AJK."}},
      {"@type":"Question","name":"Where is the SSGC consumer number?","acceptedAnswer":{"@type":"Answer","text":"The SSGC consumer number is a 10-digit number on the top section of your SSGC gas bill. SSGC covers Sindh and Balochistan. The number is labeled Consumer No. near your name and address details."}},
      {"@type":"Question","name":"How to check SNGPL gas bill online?","acceptedAnswer":{"@type":"Answer","text":"Go to pakistanbill.online/sngpl-bill/ and enter your 11-digit SNGPL consumer number. Your gas bill loads instantly showing amount due, due date, and units consumed. Free, no login required."}}
    ]
  },
  {
    "@context":"https://schema.org","@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Home","item":"https://pakistanbill.online/"},
      {"@type":"ListItem","position":2,"name":"Blog","item":"https://pakistanbill.online/blog/"},
      {"@type":"ListItem","position":3,"name":"SNGPL & SSGC Consumer Number — Where to Find It on Your Bill","item":"https://pakistanbill.online/blog/gas-bill-consumer-number/"}
    ]
  }
];
---
<BaseLayout
  title="Gas Bill Consumer Number — SNGPL & SSGC Guide"
  description="Find your SNGPL or SSGC consumer number on your gas bill. SNGPL: 11-digit number top section. SSGC: 10-digit number. Check gas bill online instantly."
  canonical="/blog/gas-bill-consumer-number/"
  schema={schema}
  lastmod="2026-03-13"
  pageType="article"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/blog/" class="hover:text-primary-600">Blog</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium truncate">SNGPL & SSGC Consumer Number — Where to ...</span>
      </nav>
