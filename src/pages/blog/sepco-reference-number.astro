---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": "https://pakistanbill.online/blog/sepco-reference-number/#article",
    "headline": "SEPCO Reference Number — Where to Find It on Your Bill",
    "description": "Find your SEPCO 14-digit reference number on your electricity bill. SEPCO covers Sukkur, Larkana, Shikarpur, Jacobabad in Sindh. Check bill instantly.",
    "datePublished": "2026-03-13", "dateModified": "2026-03-13",
    "author": {"@type":"Organization","name":"PakistanBill","@id":"https://pakistanbill.online/#organization"},
    "publisher": {"@id":"https://pakistanbill.online/#organization"}
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"Where is SEPCO reference number on bill?","acceptedAnswer":{"@type":"Answer","text":"The SEPCO reference number is at the top-right section of your bill, labeled Ref. No. It is a 14-digit number printed in bold above the barcode. SEPCO covers Sukkur, Larkana, Shikarpur, Jacobabad, Khairpur, and Kashmore districts of Sindh."}},
      {"@type":"Question","name":"SEPCO reference number format?","acceptedAnswer":{"@type":"Answer","text":"The SEPCO reference number is always 14 digits — no letters or dashes. Example: 05123456789012. It stays the same every month and is used for all online bill payments and checking."}},
      {"@type":"Question","name":"SEPCO helpline for reference number?","acceptedAnswer":{"@type":"Answer","text":"Call SEPCO helpline 074-9310260 or the national 118 number. Provide your CNIC and meter address to get your reference number. SEPCO head office is in Sukkur."}}
    ]
  },
  {
    "@context":"https://schema.org","@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Home","item":"https://pakistanbill.online/"},
      {"@type":"ListItem","position":2,"name":"Blog","item":"https://pakistanbill.online/blog/"},
      {"@type":"ListItem","position":3,"name":"SEPCO Reference Number — Where to Find It on Your Bill","item":"https://pakistanbill.online/blog/sepco-reference-number/"}
    ]
  }
];
---
<BaseLayout
  title="SEPCO Reference Number — Where to Find It on Your Bill"
  description="Find your SEPCO 14-digit reference number on your electricity bill. SEPCO covers Sukkur, Larkana, Shikarpur, Jacobabad in Sindh. Check bill instantly."
  canonical="/blog/sepco-reference-number/"
  schema={schema}
  lastmod="2026-03-13"
  pageType="article"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/blog/" class="hover:text-primary-600">Blog</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium">SEPCO</span>
      </nav>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-4">
      <span class="text-xs font-semibold text-primary-600 bg-primary-50 px-3 py-1 rounded-full">Guides</span>
      <span class="text-xs text-neutral-400 ml-3">Updated March 2026</span>
    </div>
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-4">SEPCO Reference Number — Where to Find It on Your Bill</h1>

    <h2 class="text-xl font-heading font-bold text-neutral-900 mt-8 mb-4">Frequently Asked Questions</h2>
    <div class="space-y-3 mb-10">
      <details class="faq-item"><summary class="faq-question">Where is SEPCO reference number on bill?</summary><div class="px-4 pb-4 text-sm text-neutral-600">The SEPCO reference number is at the top-right section of your bill, labeled Ref. No. It is a 14-digit number printed in bold above the barcode. SEPCO covers Sukkur, Larkana, Shikarpur, Jacobabad, Khairpur, and Kashmore districts of Sindh.</div></details>
      <details class="faq-item"><summary class="faq-question">SEPCO reference number format?</summary><div class="px-4 pb-4 text-sm text-neutral-600">The SEPCO reference number is always 14 digits — no letters or dashes. Example: 05123456789012. It stays the same every month and is used for all online bill payments and checking.</div></details>
      <details class="faq-item"><summary class="faq-question">SEPCO helpline for reference number?</summary><div class="px-4 pb-4 text-sm text-neutral-600">Call SEPCO helpline 074-9310260 or the national 118 number. Provide your CNIC and meter address to get your reference number. SEPCO head office is in Sukkur.</div></details>
    </div>

    <div class="bg-primary-50 border border-primary-200 rounded-2xl p-6 mb-8 text-center">
      <h2 class="font-bold text-xl text-primary-900 mb-2">Check Your SEPCO Bill Now</h2>
      <p class="text-primary-700 mb-4 text-sm">Free, instant, no login required.</p>
      <a href="/sepco-bill/" class="inline-block bg-primary-700 text-white px-8 py-3 rounded-xl font-bold text-lg hover:bg-primary-800 transition-colors">
        Open SEPCO Bill Checker &rarr;
      </a>
    </div>

    <div class="border-t border-neutral-200 pt-6">
      <div class="flex flex-wrap gap-2">
        <a href="/sepco-bill/" class="text-sm bg-primary-50 border border-primary-200 rounded-lg px-3 py-2 text-primary-700 font-semibold hover:underline">SEPCO Checker &rarr;</a>
        <a href="/electricity/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">All Electricity Bills &rarr;</a>
        <a href="/electricity-bill-calculator/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">Bill Calculator &rarr;</a>
        <a href="/blog/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">More Guides &rarr;</a>
      </div>
    </div>
  </div>
</BaseLayout>
