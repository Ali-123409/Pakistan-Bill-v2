---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": "https://pakistanbill.online/blog/how-to-check-bill-by-sms/#article",
    "headline": "Check Electricity Bill by SMS in Pakistan — All DISCOs 2026",
    "description": "Check your electricity bill by SMS in Pakistan. SMS your reference number to 8118 for WAPDA DISCOs. K-Electric: SMS to 8119. Free SMS bill check guide.",
    "datePublished": "2026-03-13", "dateModified": "2026-03-13",
    "author": {"@type":"Organization","name":"PakistanBill","@id":"https://pakistanbill.online/#organization"},
    "publisher": {"@id":"https://pakistanbill.online/#organization"}
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"How to check LESCO bill by SMS?","acceptedAnswer":{"@type":"Answer","text":"SMS your 14-digit LESCO reference number to 8118. You'll receive an SMS with your bill amount, due date, and units consumed. This PITC SMS service works for all WAPDA DISCOs: LESCO, MEPCO, GEPCO, FESCO, IESCO, PESCO, HESCO, SEPCO, QESCO, TESCO, and AJK."}},
      {"@type":"Question","name":"How to check K-Electric bill by SMS?","acceptedAnswer":{"@type":"Answer","text":"K-Electric customers: SMS your 13-digit account number to 8119. You'll receive your KE bill details by return SMS. Alternatively, use the WhatsApp service by sending your account number to KE's official WhatsApp number 021-38500001."}},
      {"@type":"Question","name":"Is SMS bill check free?","acceptedAnswer":{"@type":"Answer","text":"The PITC SMS service (8118) charges standard SMS rates — typically Rs 1-3 per SMS depending on your network. It is not free, but much cheaper and faster than visiting a DISCO office. Online check at pakistanbill.online is completely free."}}
    ]
  },
  {
    "@context":"https://schema.org","@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Home","item":"https://pakistanbill.online/"},
      {"@type":"ListItem","position":2,"name":"Blog","item":"https://pakistanbill.online/blog/"},
      {"@type":"ListItem","position":3,"name":"Check Electricity Bill by SMS in Pakistan — All DISCOs 2026","item":"https://pakistanbill.online/blog/how-to-check-bill-by-sms/"}
    ]
  }
];
---
<BaseLayout
  title="Check Electricity Bill by SMS in Pakistan — All DISCOs 2026"
  description="Check your electricity bill by SMS in Pakistan. SMS your reference number to 8118 for WAPDA DISCOs. K-Electric: SMS to 8119. Free SMS bill check guide."
  canonical="/blog/how-to-check-bill-by-sms/"
  schema={schema}
  lastmod="2026-03-13"
  pageType="article"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/blog/" class="hover:text-primary-600">Blog</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium">All DISCOs</span>
      </nav>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-4">
      <span class="text-xs font-semibold text-primary-600 bg-primary-50 px-3 py-1 rounded-full">Guides</span>
      <span class="text-xs text-neutral-400 ml-3">Updated March 2026</span>
    </div>
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-4">Check Electricity Bill by SMS in Pakistan — All DISCOs 2026</h1>

    <h2 class="text-xl font-heading font-bold text-neutral-900 mt-8 mb-4">Frequently Asked Questions</h2>
    <div class="space-y-3 mb-10">
      <details class="faq-item"><summary class="faq-question">How to check LESCO bill by SMS?</summary><div class="px-4 pb-4 text-sm text-neutral-600">SMS your 14-digit LESCO reference number to 8118. You'll receive an SMS with your bill amount, due date, and units consumed. This PITC SMS service works for all WAPDA DISCOs: LESCO, MEPCO, GEPCO, FESCO, IESCO, PESCO, HESCO, SEPCO, QESCO, TESCO, and AJK.</div></details>
      <details class="faq-item"><summary class="faq-question">How to check K-Electric bill by SMS?</summary><div class="px-4 pb-4 text-sm text-neutral-600">K-Electric customers: SMS your 13-digit account number to 8119. You'll receive your KE bill details by return SMS. Alternatively, use the WhatsApp service by sending your account number to KE's official WhatsApp number 021-38500001.</div></details>
      <details class="faq-item"><summary class="faq-question">Is SMS bill check free?</summary><div class="px-4 pb-4 text-sm text-neutral-600">The PITC SMS service (8118) charges standard SMS rates — typically Rs 1-3 per SMS depending on your network. It is not free, but much cheaper and faster than visiting a DISCO office. Online check at pakistanbill.online is completely free.</div></details>
    </div>

    <div class="bg-primary-50 border border-primary-200 rounded-2xl p-6 mb-8 text-center">
      <h2 class="font-bold text-xl text-primary-900 mb-2">Check Your All DISCOs Bill Now</h2>
      <p class="text-primary-700 mb-4 text-sm">Free, instant, no login required.</p>
      <a href="/dashboard/" class="inline-block bg-primary-700 text-white px-8 py-3 rounded-xl font-bold text-lg hover:bg-primary-800 transition-colors">
        Open All DISCOs Bill Checker &rarr;
      </a>
    </div>

    <div class="border-t border-neutral-200 pt-6">
      <div class="flex flex-wrap gap-2">
        <a href="/dashboard/" class="text-sm bg-primary-50 border border-primary-200 rounded-lg px-3 py-2 text-primary-700 font-semibold hover:underline">All DISCOs Checker &rarr;</a>
        <a href="/electricity/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">All Electricity Bills &rarr;</a>
        <a href="/electricity-bill-calculator/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">Bill Calculator &rarr;</a>
        <a href="/blog/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">More Guides &rarr;</a>
      </div>
    </div>
  </div>
