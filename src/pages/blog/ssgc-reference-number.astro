---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": "https://pakistanbill.online/blog/ssgc-reference-number/#article",
    "headline": "SSGC Consumer Number — Find It on Your Gas Bill",
    "description": "Find your SSGC 10-digit consumer number on your gas bill. SSGC covers Karachi, Sindh, Balochistan. Check SSGC gas bill online instantly.",
    "datePublished": "2026-03-13", "dateModified": "2026-03-13",
    "author": {"@type":"Organization","name":"PakistanBill","@id":"https://pakistanbill.online/#organization"},
    "publisher": {"@id":"https://pakistanbill.online/#organization"}
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"Where is the SSGC consumer number on the gas bill?","acceptedAnswer":{"@type":"Answer","text":"The SSGC consumer number is at the top section of your SSGC gas bill, labeled Consumer No. or Consumer Number. It is a 10-digit number near your name and address. SSGC covers Karachi, entire Sindh, and Balochistan."}},
      {"@type":"Question","name":"SSGC consumer number vs reference number?","acceptedAnswer":{"@type":"Answer","text":"SSGC uses Consumer Number (10 digits) — not a reference number like WAPDA electricity bills. This consumer number is used for all online bill checks, payments through JazzCash, EasyPaisa, and bank apps. It never changes."}},
      {"@type":"Question","name":"SSGC helpline for consumer number?","acceptedAnswer":{"@type":"Answer","text":"Call SSGC helpline 021-111-786-100 (Karachi) or 0800-00786 (toll free). Provide your CNIC and address. You can also visit any SSGC customer service center in Karachi, Hyderabad, Sukkur, or Quetta."}}
    ]
  },
  {
    "@context":"https://schema.org","@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Home","item":"https://pakistanbill.online/"},
      {"@type":"ListItem","position":2,"name":"Blog","item":"https://pakistanbill.online/blog/"},
      {"@type":"ListItem","position":3,"name":"SSGC Consumer Number — Find It on Your Gas Bill","item":"https://pakistanbill.online/blog/ssgc-reference-number/"}
    ]
  }
];
---
<BaseLayout
  title="SSGC Consumer Number — Find It on Your Gas Bill"
  description="Find your SSGC 10-digit consumer number on your gas bill. SSGC covers Karachi, Sindh, Balochistan. Check SSGC gas bill online instantly."
  canonical="/blog/ssgc-reference-number/"
  schema={schema}
  lastmod="2026-03-13"
  pageType="article"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/blog/" class="hover:text-primary-600">Blog</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium">SSGC</span>
      </nav>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-4">
      <span class="text-xs font-semibold text-primary-600 bg-primary-50 px-3 py-1 rounded-full">Guides</span>
      <span class="text-xs text-neutral-400 ml-3">Updated March 2026</span>
    </div>
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-4">SSGC Consumer Number — Find It on Your Gas Bill</h1>

    <h2 class="text-xl font-heading font-bold text-neutral-900 mt-8 mb-4">Frequently Asked Questions</h2>
    <div class="space-y-3 mb-10">
      <details class="faq-item"><summary class="faq-question">Where is the SSGC consumer number on the gas bill?</summary><div class="px-4 pb-4 text-sm text-neutral-600">The SSGC consumer number is at the top section of your SSGC gas bill, labeled Consumer No. or Consumer Number. It is a 10-digit number near your name and address. SSGC covers Karachi, entire Sindh, and Balochistan.</div></details>
      <details class="faq-item"><summary class="faq-question">SSGC consumer number vs reference number?</summary><div class="px-4 pb-4 text-sm text-neutral-600">SSGC uses Consumer Number (10 digits) — not a reference number like WAPDA electricity bills. This consumer number is used for all online bill checks, payments through JazzCash, EasyPaisa, and bank apps. It never changes.</div></details>
      <details class="faq-item"><summary class="faq-question">SSGC helpline for consumer number?</summary><div class="px-4 pb-4 text-sm text-neutral-600">Call SSGC helpline 021-111-786-100 (Karachi) or 0800-00786 (toll free). Provide your CNIC and address. You can also visit any SSGC customer service center in Karachi, Hyderabad, Sukkur, or Quetta.</div></details>
    </div>

    <div class="bg-primary-50 border border-primary-200 rounded-2xl p-6 mb-8 text-center">
      <h2 class="font-bold text-xl text-primary-900 mb-2">Check Your SSGC Bill Now</h2>
      <p class="text-primary-700 mb-4 text-sm">Free, instant, no login required.</p>
      <a href="/ssgc-bill/" class="inline-block bg-primary-700 text-white px-8 py-3 rounded-xl font-bold text-lg hover:bg-primary-800 transition-colors">
        Open SSGC Bill Checker &rarr;
      </a>
    </div>

    <div class="border-t border-neutral-200 pt-6">
      <div class="flex flex-wrap gap-2">
        <a href="/ssgc-bill/" class="text-sm bg-primary-50 border border-primary-200 rounded-lg px-3 py-2 text-primary-700 font-semibold hover:underline">SSGC Checker &rarr;</a>
        <a href="/electricity/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">All Electricity Bills &rarr;</a>
        <a href="/electricity-bill-calculator/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">Bill Calculator &rarr;</a>
        <a href="/blog/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-600 hover:underline">More Guides &rarr;</a>
      </div>
    </div>
  </div>
</BaseLayout>
