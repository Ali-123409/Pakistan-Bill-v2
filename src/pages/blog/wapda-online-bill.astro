---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "@id": "https://pakistanbill.online/blog/wapda-online-bill/#article",
    "headline": "WAPDA Online Bill Check 2026 — All DISCOs",
    "description": "Check WAPDA electricity bill online for all DISCOs. LESCO, MEPCO, GEPCO, FESCO, IESCO, PESCO, HESCO, SEPCO, QESCO. Enter reference number — instant result.",
    "datePublished": "2026-03-13", "dateModified": "2026-03-13",
    "author": {"@type":"Organization","name":"PakistanBill","@id":"https://pakistanbill.online/#organization"},
    "publisher": {"@id":"https://pakistanbill.online/#organization"}
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"What is WAPDA online bill check?","acceptedAnswer":{"@type":"Answer","text":"WAPDA online bill check lets you view your electricity bill by entering your 14-digit reference number. PakistanBill.online provides bill checking for all 11 WAPDA DISCOs including LESCO, MEPCO, GEPCO, FESCO, IESCO, PESCO, HESCO, SEPCO, QESCO, TESCO, and AJK."}},
      {"@type":"Question","name":"Which website to check WAPDA bill?","acceptedAnswer":{"@type":"Answer","text":"Use pakistanbill.online to check any WAPDA electricity bill. We cover all 11 DISCOs. Select your company (LESCO, MEPCO, etc.), enter your 14-digit reference number, and your bill loads instantly."}},
      {"@type":"Question","name":"How to find WAPDA reference number?","acceptedAnswer":{"@type":"Answer","text":"Your WAPDA reference number is a 14-digit number on the top-right section of your electricity bill, labeled Ref. No. or Reference No. It is above the barcode on the bill."}}
    ]
  },
  {
    "@context":"https://schema.org","@type":"BreadcrumbList",
    "itemListElement":[
      {"@type":"ListItem","position":1,"name":"Home","item":"https://pakistanbill.online/"},
      {"@type":"ListItem","position":2,"name":"Blog","item":"https://pakistanbill.online/blog/"},
      {"@type":"ListItem","position":3,"name":"WAPDA Online Bill Check 2026 — All DISCOs","item":"https://pakistanbill.online/blog/wapda-online-bill/"}
    ]
  }
];
---
<BaseLayout
  title="WAPDA Online Bill Check 2026 — All DISCO Bills"
  description="Check WAPDA electricity bill online for all DISCOs. LESCO, MEPCO, GEPCO, FESCO, IESCO, PESCO, HESCO, SEPCO, QESCO. Enter reference number — instant result."
  canonical="/blog/wapda-online-bill/"
  schema={schema}
  lastmod="2026-03-13"
  pageType="article"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/blog/" class="hover:text-primary-600">Blog</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium truncate">WAPDA Online Bill Check 2026 — All DISCO...</span>
      </nav>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6">
      <span class="text-xs font-semibold text-primary-600 bg-primary-50 px-3 py-1 rounded-full">Guides</span>
      <span class="text-xs text-neutral-400 ml-3">Updated March 2026</span>
    </div>
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-4">WAPDA Online Bill Check — All DISCOs 2026</h1>
    <p class="text-neutral-600 mb-8 text-lg leading-relaxed">WAPDA (Water and Power Development Authority) distributes electricity through 11 DISCOs across Pakistan. Each DISCO has its own bill checker. PakistanBill.online covers all of them — one platform for every WAPDA electricity consumer.</p>

    <h2 class="text-2xl font-heading font-bold mt-8 mb-4">Frequently Asked Questions</h2>
    <div class="space-y-3 mb-10">
      <details class="faq-item"><summary class="faq-question">What is WAPDA online bill check?</summary><div class="px-4 pb-4 text-sm text-neutral-600">WAPDA online bill check lets you view your electricity bill by entering your 14-digit reference number. PakistanBill.online provides bill checking for all 11 WAPDA DISCOs including LESCO, MEPCO, GEPCO, FESCO, IESCO, PESCO, HESCO, SEPCO, QESCO, TESCO, and AJK.</div></details>
      <details class="faq-item"><summary class="faq-question">Which website to check WAPDA bill?</summary><div class="px-4 pb-4 text-sm text-neutral-600">Use pakistanbill.online to check any WAPDA electricity bill. We cover all 11 DISCOs. Select your company (LESCO, MEPCO, etc.), enter your 14-digit reference number, and your bill loads instantly.</div></details>
      <details class="faq-item"><summary class="faq-question">How to find WAPDA reference number?</summary><div class="px-4 pb-4 text-sm text-neutral-600">Your WAPDA reference number is a 14-digit number on the top-right section of your electricity bill, labeled Ref. No. or Reference No. It is above the barcode on the bill.</div></details>
    </div>

    <div class="border-t border-neutral-200 pt-6">
      <h2 class="font-bold text-neutral-800 mb-4">Related Pages</h2>
      <div class="flex flex-wrap gap-2">
        <a href="/lesco-bill/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-primary-600 hover:underline font-medium">LESCO Bill →</a>
        <a href="/mepco-bill/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-primary-600 hover:underline font-medium">MEPCO Bill →</a>
        <a href="/gepco-bill/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-primary-600 hover:underline font-medium">GEPCO Bill →</a>
        <a href="/fesco-bill/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-primary-600 hover:underline font-medium">FESCO Bill →</a>
        <a href="/iesco-bill/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-primary-600 hover:underline font-medium">IESCO Bill →</a>
        <a href="/electricity/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-primary-600 hover:underline font-medium">All Electricity Bills →</a>
      </div>
    </div>
  </div>
</BaseLayout>
