<script>
  function checkPTCL() {
    const phone = (document.getElementById('ptcl-phone') as HTMLInputElement).value.trim();
    const account = (document.getElementById('ptcl-account') as HTMLInputElement).value.trim();
    const err = document.getElementById('ptcl-error');
    if (!phone && !account) {
      err!.style.display = 'block';
      err!.textContent = 'Enter your PTCL phone number OR Account ID.';
      return;
    }
    err!.style.display = 'none';
    if (account && account.length === 10) {
      window.open(`https://dbill.ptcl.net.pk/bill?account=${account}`, '_blank');
    } else if (phone) {
      window.open(`https://dbill.ptcl.net.pk/bill?phone=${phone}`, '_blank');
    }
  }
</script>
