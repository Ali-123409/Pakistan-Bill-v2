---
const title = "Contact PakistanBill.online";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content="Contact PakistanBill.online for feedback, corrections, or partnership enquiries." />
  <link rel="canonical" href="https://pakistanbill.online/contact/" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
<header class="site-header">
  <div class="container">
    <a href="/" class="logo">PakistanBill<span>.online</span></a>
    <nav><a href="/">Home</a><a href="/about/">About</a><a href="/contact/" class="active">Contact</a></nav>
  </div>
</header>
<main>
  <section style="padding: 4rem 0; background: linear-gradient(135deg, #01411C 0%, #02521F 100%); color: white;">
    <div class="container">
      <h1>Contact Us</h1>
      <p>Feedback, corrections, or partnership enquiries — we read everything.</p>
    </div>
  </section>
  <section style="padding: 4rem 0;">
    <div class="container" style="max-width: 700px;">
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 3rem;">
        <div style="background: #f8f9fa; border-radius: 12px; padding: 2rem; border-left: 4px solid #01411C;">
          <h3>📧 General Enquiries</h3>
          <p>info@pakistanbill.online</p>
          <p style="color: #666; font-size: 0.9rem;">Response within 48 hours</p>
        </div>
        <div style="background: #f8f9fa; border-radius: 12px; padding: 2rem; border-left: 4px solid #01411C;">
          <h3>🔧 Bill Data Issues</h3>
          <p>corrections@pakistanbill.online</p>
          <p style="color: #666; font-size: 0.9rem;">Incorrect tariff rates, broken tools</p>
        </div>
        <div style="background: #f8f9fa; border-radius: 12px; padding: 2rem; border-left: 4px solid #01411C;">
          <h3>🤝 Partnerships</h3>
          <p>partners@pakistanbill.online</p>
          <p style="color: #666; font-size: 0.9rem;">Advertising, content collaboration</p>
        </div>
        <div style="background: #f8f9fa; border-radius: 12px; padding: 2rem; border-left: 4px solid #01411C;">
          <h3>❓ Need Bill Help?</h3>
          <p>Visit your <a href="/">provider's page</a> and check the FAQ or helpline section — most questions are answered there instantly.</p>
        </div>
      </div>

      <div style="background: #fff3cd; border-radius: 12px; padding: 1.5rem; border-left: 4px solid #ffc107;">
        <h3 style="margin: 0 0 0.5rem;">⚠️ We Cannot Help With Your Actual Bill</h3>
        <p style="margin: 0;">PakistanBill.online is an information platform only. For actual billing disputes, disconnection issues, or meter problems, contact your utility provider directly. We list every helpline number on each provider's page.</p>
      </div>
    </div>
  </section>
</main>
<footer class="site-footer">
  <div class="container">
    <p>© 2026 PakistanBill.online · <a href="/privacy-policy/">Privacy Policy</a> · <a href="/disclaimer/">Disclaimer</a></p>
  </div>
</footer>
</body>
</html>
