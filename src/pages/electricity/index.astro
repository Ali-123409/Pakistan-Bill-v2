---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://pakistanbill.online/electricity/#webpage",
    "url": "https://pakistanbill.online/electricity/",
    "name": "Electricity Bill Checker Pakistan — All DISCO Bill Check Online 2026",
    "description": "Check electricity bills for all Pakistan DISCOs: LESCO, MEPCO, GEPCO, FESCO, IESCO, PESCO, HESCO, SEPCO, QESCO, TESCO, AJK, K-Electric. Free, instant, no login.",
    "isPartOf": {"@id": "https://pakistanbill.online/#website"},
    "dateModified": "2026-03-11"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"Home","item":"https://pakistanbill.online/"},
      {"@type":"ListItem","position":2,"name":"Electricity Bills","item":"https://pakistanbill.online/electricity/"}
    ]
  }
];
---
<BaseLayout
  title="Electricity Bill Checker Pakistan — All DISCO Bills Online"
  description="Check electricity bills for all Pakistan DISCOs: LESCO, MEPCO, GEPCO, FESCO, IESCO, PESCO, HESCO, SEPCO, QESCO, TESCO, AJK, K-Electric. Free, instant, no login."
  canonical="/electricity/"
  schema={schema}
  lastmod="2026-03-11"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium">Electricity Bills</span>
      </nav>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-3">Electricity Bill Checker — All Pakistan DISCOs</h1>
    <p class="text-lg text-neutral-600 mb-8">Check electricity bills for all Pakistan DISCOs: LESCO, MEPCO, GEPCO, FESCO, IESCO, PESCO, HESCO, SEPCO, QESCO, TESCO, AJK, K-Electric. Free, instant, no login.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
      
      <a href="/lesco-bill/" class="bg-white border-2 border-neutral-200 rounded-2xl p-5 hover:border-primary-400 hover:shadow-md transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">LESCO</h2>
        <p class="text-xs text-neutral-400 font-medium uppercase tracking-wide mb-2">Lahore</p>
        <p class="text-sm text-neutral-500 mb-3">Lahore, Kasur, Sheikhupura, Nankana Sahib</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check LESCO Bill →</span>
      </a>
      <a href="/mepco-bill/" class="bg-white border-2 border-neutral-200 rounded-2xl p-5 hover:border-primary-400 hover:shadow-md transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">MEPCO</h2>
        <p class="text-xs text-neutral-400 font-medium uppercase tracking-wide mb-2">South Punjab</p>
        <p class="text-sm text-neutral-500 mb-3">Multan, Bahawalpur, Sahiwal, DG Khan, Vehari</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check MEPCO Bill →</span>
      </a>
      <a href="/gepco-bill/" class="bg-white border-2 border-neutral-200 rounded-2xl p-5 hover:border-primary-400 hover:shadow-md transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">GEPCO</h2>
        <p class="text-xs text-neutral-400 font-medium uppercase tracking-wide mb-2">Gujranwala</p>
        <p class="text-sm text-neutral-500 mb-3">Gujranwala, Sialkot, Gujrat, Narowal, Hafizabad</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check GEPCO Bill →</span>
      </a>
      <a href="/fesco-bill/" class="bg-white border-2 border-neutral-200 rounded-2xl p-5 hover:border-primary-400 hover:shadow-md transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">FESCO</h2>
        <p class="text-xs text-neutral-400 font-medium uppercase tracking-wide mb-2">Faisalabad</p>
        <p class="text-sm text-neutral-500 mb-3">Faisalabad, Jhang, Chiniot, Toba Tek Singh, Sargodha</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check FESCO Bill →</span>
      </a>
      <a href="/iesco-bill/" class="bg-white border-2 border-neutral-200 rounded-2xl p-5 hover:border-primary-400 hover:shadow-md transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">IESCO</h2>
        <p class="text-xs text-neutral-400 font-medium uppercase tracking-wide mb-2">Islamabad</p>
        <p class="text-sm text-neutral-500 mb-3">Islamabad, Rawalpindi, Attock, Chakwal, Jhelum</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check IESCO Bill →</span>
      </a>
      <a href="/pesco-bill/" class="bg-white border-2 border-neutral-200 rounded-2xl p-5 hover:border-primary-400 hover:shadow-md transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">PESCO</h2>
        <p class="text-xs text-neutral-400 font-medium uppercase tracking-wide mb-2">Peshawar</p>
        <p class="text-sm text-neutral-500 mb-3">Peshawar, Mardan, Swat, Abbottabad, Malakand</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check PESCO Bill →</span>
      </a>
      <a href="/hesco-bill/" class="bg-white border-2 border-neutral-200 rounded-2xl p-5 hover:border-primary-400 hover:shadow-md transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">HESCO</h2>
        <p class="text-xs text-neutral-400 font-medium uppercase tracking-wide mb-2">Hyderabad</p>
        <p class="text-sm text-neutral-500 mb-3">Hyderabad, Mirpurkhas, Tharparkar, Badin</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check HESCO Bill →</span>
      </a>
      <a href="/sepco-bill/" class="bg-white border-2 border-neutral-200 rounded-2xl p-5 hover:border-primary-400 hover:shadow-md transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">SEPCO</h2>
        <p class="text-xs text-neutral-400 font-medium uppercase tracking-wide mb-2">Sukkur</p>
        <p class="text-sm text-neutral-500 mb-3">Sukkur, Larkana, Khairpur, Ghotki, Jacobabad</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check SEPCO Bill →</span>
      </a>
      <a href="/qesco-bill/" class="bg-white border-2 border-neutral-200 rounded-2xl p-5 hover:border-primary-400 hover:shadow-md transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">QESCO</h2>
        <p class="text-xs text-neutral-400 font-medium uppercase tracking-wide mb-2">Quetta</p>
        <p class="text-sm text-neutral-500 mb-3">All 34 Balochistan districts (excl. Lasbela)</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check QESCO Bill →</span>
      </a>
      <a href="/tesco-bill/" class="bg-white border-2 border-neutral-200 rounded-2xl p-5 hover:border-primary-400 hover:shadow-md transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">TESCO</h2>
        <p class="text-xs text-neutral-400 font-medium uppercase tracking-wide mb-2">Tribal Districts</p>
        <p class="text-sm text-neutral-500 mb-3">7 Merged Tribal Districts — FATA/KPK merged areas</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check TESCO Bill →</span>
      </a>
      <a href="/ajk-bill/" class="bg-white border-2 border-neutral-200 rounded-2xl p-5 hover:border-primary-400 hover:shadow-md transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">AJK / AJKED</h2>
        <p class="text-xs text-neutral-400 font-medium uppercase tracking-wide mb-2">Azad Kashmir</p>
        <p class="text-sm text-neutral-500 mb-3">Azad Kashmir — Muzaffarabad, Mirpur, Rawalakot</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check AJK / AJKED Bill →</span>
      </a>
      <a href="/k-electric-bill/" class="bg-white border-2 border-neutral-200 rounded-2xl p-5 hover:border-primary-400 hover:shadow-md transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">K-Electric</h2>
        <p class="text-xs text-neutral-400 font-medium uppercase tracking-wide mb-2">Karachi</p>
        <p class="text-sm text-neutral-500 mb-3">Karachi, Hub (Lasbela), Dhabeji</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check K-Electric Bill →</span>
      </a>
    </div>

    <div class="bg-primary-50 border border-primary-200 rounded-2xl p-5 mb-8">
      <h2 class="font-bold text-primary-800 mb-2">⚡ Check Any Bill Without Switching Pages</h2>
      <p class="text-sm text-primary-700 mb-3">Use our universal dashboard — toggle between all 19 utility providers instantly.</p>
      <a href="/dashboard/" class="inline-block bg-primary-700 text-white px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-primary-800 transition-colors">Open Bill Dashboard →</a>
    </div>

    <div class="border-t border-neutral-200 pt-6">
      <h2 class="font-bold text-neutral-800 text-sm mb-3 uppercase tracking-wider">All Utility Bill Silos</h2>
      <div class="flex flex-wrap gap-3">
        <a href="/electricity/" class="font-semibold text-sm bg-yellow-50 border border-yellow-200 rounded-lg px-4 py-2 text-yellow-800 hover:bg-yellow-100">⚡ Electricity Bills</a>
        <a href="/gas/" class="font-semibold text-sm bg-orange-50 border border-orange-200 rounded-lg px-4 py-2 text-orange-800 hover:bg-orange-100">🔥 Gas Bills</a>
        <a href="/telecom/" class="font-semibold text-sm bg-blue-50 border border-blue-200 rounded-lg px-4 py-2 text-blue-800 hover:bg-blue-100">📞 Telecom Bills</a>
        <a href="/water/" class="font-semibold text-sm bg-cyan-50 border border-cyan-200 rounded-lg px-4 py-2 text-cyan-800 hover:bg-cyan-100">💧 Water Bills</a>
      </div>
    </div>
  </div>

<p style="margin:1rem 0;line-height:1.8;">PakistanBill.online is <strong>Pakistan's only platform</strong> covering <em>all</em> utility categories. Beyond electricity, we also cover gas bills — <a href="/sngpl-bill/">SNGPL</a> (Punjab, KPK) and <a href="/ssgc-bill/">SSGC</a> (Sindh, Balochistan) — plus <a href="/ptcl-bill/">PTCL telecom bills</a> and all three <a href="/water/">WASA water bills</a> for Lahore, Rawalpindi and Faisalabad. Use our <a href="/electricity-bill-calculator/">electricity bill calculator</a> or open the <a href="/dashboard/">universal bill dashboard</a> to check all providers at once.</p>
</BaseLayout>
