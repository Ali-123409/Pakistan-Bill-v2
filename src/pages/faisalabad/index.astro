---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = [{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://pakistanbill.online/faisalabad/#webpage",
  "url": "https://pakistanbill.online/faisalabad/",
  "name": "Utility Bill Check Faisalabad — Electricity, Gas & Water Bills Online",
  "description": "Check all utility bills in Faisalabad: FESCO electricity bill, SNGPL gas bill, and WASA Faisalabad water bill. Find Faisalabad utility office addresses, helplines, and bill payment guides.",
  "isPartOf": {"@id": "https://pakistanbill.online/#website"},
  "dateModified": "2026-03-11"
},
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"How to check electricity bill in Faisalabad?","acceptedAnswer":{"@type":"Answer","text":"Residents of Faisalabad get electricity from FESCO. Check your Faisalabad electricity bill at pakistanbill.online/fesco-bill/ by entering your 14-digit reference number. Free, instant, no login."}},
      {"@type":"Question","name":"How to check gas bill in Faisalabad?","acceptedAnswer":{"@type":"Answer","text":"Faisalabad gas consumers use SNGPL. Check your Faisalabad gas bill at pakistanbill.online/sngpl-bill/ by entering your consumer number. For complaints call 1199."}},
  ]
}];
---
<BaseLayout
  title="Bill Check Faisalabad 2026 — FESCO, SNGPL, WASA Faisalabad Online"
  description="Check FESCO electricity, SNGPL gas, and WASA bills in Faisalabad. Helplines, office addresses, and payment guide. Updated 2026."
  canonical="/faisalabad/"
  schema={schema}
  lastmod="2026-03-11"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium">Faisalabad Utility Bills</span>
      </nav>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-2">Utility Bill Check — Faisalabad, Punjab</h1>
    <p class="text-lg text-neutral-600 mb-8">Faisalabad (4 million residents) gets electricity from <strong>FESCO</strong>, gas from <strong>SNGPL</strong>, and water from <strong>WASA Faisalabad</strong>. Check any Faisalabad utility bill below instantly.</p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
      <a href="/fesco-bill/" class="bg-white border-2 border-primary-200 rounded-2xl p-5 hover:border-primary-500 transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">FESCO Electricity</h2>
        <p class="text-sm text-neutral-500 mb-3">Check Faisalabad electricity bill by 14-digit reference number</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check FESCO Bill →</span>
      </a>
      <a href="/sngpl-bill/" class="bg-white border-2 border-orange-200 rounded-2xl p-5 hover:border-orange-500 transition-all group">
        <div class="text-3xl mb-3">🔥</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">SNGPL Gas</h2>
        <p class="text-sm text-neutral-500 mb-3">Check Faisalabad gas bill by consumer number</p>
        <span class="text-orange-600 font-semibold text-sm group-hover:underline">Check SNGPL Bill →</span>
      </a>
      <a href="/wasa-faisalabad-bill/" class="bg-white border-2 border-blue-200 rounded-2xl p-5 hover:border-blue-500 transition-all group">
        <div class="text-3xl mb-3">💧</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">WASA Faisalabad</h2>
        <p class="text-sm text-neutral-500 mb-3">Check Faisalabad water bill online</p>
        <span class="text-blue-600 font-semibold text-sm group-hover:underline">Check Water Bill →</span>
      </a>
    </div>

    <div class="bg-primary-50 border border-primary-200 rounded-2xl p-5 mb-8">
      <h2 class="font-bold text-primary-800 mb-2">⚡ Fast: Check Your Faisalabad Bill Right Now</h2>
      <p class="text-sm text-primary-700 mb-3">Use our dashboard to check any Faisalabad utility bill — electricity, gas, or telecom — without switching pages.</p>
      <a href="/dashboard/" class="inline-block bg-primary-700 text-white px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-primary-800 transition-colors">Open Bill Dashboard →</a>
    </div>

    <h2 class="text-xl font-heading font-bold mb-4">How to Pay Utility Bills in Faisalabad</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
      {[
        ["JazzCash App","Bill Payments → Electricity/Gas → Enter ref/consumer number"],
        ["EasyPaisa","Bill Payments → Select utility → Enter account number"],
        ["HBL / MCB / Meezan","Bank app → Bill Payments → Select provider"],
        ["1-Link ATM","Bill Payment → Select utility biller code → Enter number"],
        ["Utility Office","Walk-in payment at nearest FESCO / SNGPL office in Faisalabad"],
        ["QR Code on Bill","Scan QR printed on your Faisalabad bill with any bank app"],
      ].map((item) => (
        <div class="bg-white border border-neutral-200 rounded-xl p-3">
          <h3 class="font-semibold text-neutral-800 text-sm">{item[0]}</h3>
          <p class="text-xs text-neutral-500 mt-1">{item[1]}</p>
        </div>
      ))}
    </div>

    <h2 class="text-xl font-heading font-bold mb-4">Frequently Asked Questions — Faisalabad Utility Bills</h2>
    <div class="space-y-3">
      {[
        { q: `How to check electricity bill in Faisalabad?`, a: `Faisalabad residents receive electricity from FESCO. Enter your 14-digit FESCO reference number at our FESCO bill checker — pakistanbill.online/fesco-bill/. Your bill appears instantly, free, no login required.` }},
        { q: `How to check gas bill in Faisalabad?`, a: `Faisalabad consumers use SNGPL for gas supply. Visit pakistanbill.online/sngpl-bill/ and enter your consumer number. For complaints or emergencies call SNGPL helpline 1199.` }},
        { q: `How to pay electricity bill online in Faisalabad?`, a: `Pay your Faisalabad FESCO electricity bill through JazzCash, EasyPaisa, HBL, MCB, Meezan bank apps, or scan the QR code on your bill. All payment apps support FESCO bill payments using your 14-digit reference number.` }},
        { q: `What is the grace period for electricity bill in Faisalabad?`, a: `FESCO gives 7 days after the due date to pay without a 10% late payment surcharge. Pay before your due date to avoid extra charges. Check your due date using our FESCO bill checker above.` }},
        { q: `How to download duplicate electricity bill in Faisalabad?`, a: `Check your FESCO bill at pakistanbill.online/fesco-bill/, then click Download PDF. Your Faisalabad electricity duplicate bill downloads instantly. You can print it at any shop or pay using the bill number.` }},
      ].map((faq) => (
        <details class="faq-item">
          <summary class="faq-question">{faq.q}</summary>
          <div class="px-4 pb-4 text-sm text-neutral-600">{faq.a}</div>
        </details>
      ))}
    </div>
  </div>
<p style="margin:1rem 0;padding:1rem;background:#f0fdf4;border-left:4px solid #16a34a;border-radius:0 8px 8px 0;font-size:0.9rem;line-height:1.7;">PakistanBill.online is <strong>Pakistan's only platform</strong> covering all utility bills in Faisalabad and every other city in Pakistan. Check all Faisalabad bills here: <a href="/fesco-bill/">FESCO electricity</a> | <a href="/sngpl-bill/">SNGPL gas</a> | <a href="/wasa-faisalabad-bill/">WASA Faisalabad water</a> | <a href="/ptcl-bill/">PTCL telecom</a> | <a href="/electricity-bill-calculator/">electricity bill calculator</a> | <a href="/dashboard/">all bills dashboard</a>. Also check nearby cities: <a href="/lahore/">Lahore</a> | <a href="/gujranwala/">Gujranwala</a> | <a href="/multan/">Multan</a>.</p>
</BaseLayout>
