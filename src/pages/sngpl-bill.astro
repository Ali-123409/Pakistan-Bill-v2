  <script type="application/ld+json">{"@context":"https://schema.org","@type":"WebPage","@id":"https://pakistanbill.online/sngpl-bill/#webpage","url":"https://pakistanbill.online/sngpl-bill/","name":"SNGPL Bill Online — Sui Northern Gas Bill","description":"Check SNGPL Sui Northern Gas bill online for Punjab, KPK, Islamabad and AJK by 11-digit consumer number.","isPartOf":{"@id":"https://pakistanbill.online/#website"},"dateModified":"2026-03-11","inLanguage":"en-PK"}</script>
