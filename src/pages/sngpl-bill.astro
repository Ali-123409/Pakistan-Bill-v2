---
const title = "SNGPL Bill Online — Check Sui Northern Gas Bill March 2026";
const desc = "Check your SNGPL gas bill online by 11-digit consumer number. View your Sui Northern Gas Pipelines bill for Punjab, KPK, Islamabad, and AJK — free, no login required.";
const canonical = "https://pakistanbill.online/sngpl-bill/";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How do I check my SNGPL gas bill online?", "acceptedAnswer": { "@type": "Answer", "text": "Visit sngpl.com.pk, go to Customer Services and click View/Print Bill. Enter your 11-digit SNGPL consumer number — printed on the top of any previous gas bill — and click Submit. Your latest SNGPL bill appears with amount due, due date, meter readings, and consumption in MMBTU." } },
    { "@type": "Question", "name": "What is the SNGPL 11-digit consumer number?", "acceptedAnswer": { "@type": "Answer", "text": "Your SNGPL consumer number is an 11-digit number that uniquely identifies your gas connection. It is printed prominently on the top section of every SNGPL gas bill. Unlike electricity bills which use 14 digits, SNGPL uses 11 digits. Save it in your phone — this number is permanent for your connection." } },
    { "@type": "Question", "name": "What is SNGPL helpline number?", "acceptedAnswer": { "@type": "Answer", "text": "SNGPL helpline is 1199 — available 24/7 for gas leakage emergencies, billing complaints, new connection queries, and gas theft reports." } },
  ]
};

const howtoSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Check SNGPL Gas Bill Online",
  "totalTime": "PT2M",
  "estimatedCost": { "@type": "MonetaryAmount", "currency": "PKR", "value": "0" },
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Find Consumer Number", "text": "Locate your 11-digit SNGPL consumer number on the top of any previous gas bill." },
    { "@type": "HowToStep", "position": 2, "name": "Visit SNGPL Portal", "text": "Go to sngpl.com.pk and click Customer Services, then View/Print Bill." },
    { "@type": "HowToStep", "position": 3, "name": "Enter Consumer Number", "text": "Type your 11-digit consumer number and click Submit." },
    { "@type": "HowToStep", "position": 4, "name": "View Your Bill", "text": "Your SNGPL bill appears with amount, due date, and consumption details." },
  ]
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://pakistanbill.online/" },
    { "@type": "ListItem", "position": 2, "name": "Gas Bills", "item": "https://pakistanbill.online/#gas" },
    { "@type": "ListItem", "position": 3, "name": "SNGPL Gas Bill", "item": canonical }
  ]
};

const tariffSlabs2026 = [
  { cat: "Protected (up to 0.5 HCFT/day avg)", rate: "Rs 400.00/MMBTU", note: "Subsidized rate for low users" },
  { cat: "Unprotected Slab 1 (0.5–1.0 HCFT/day avg)", rate: "Rs 1,597.17/MMBTU", note: "" },
  { cat: "Unprotected Slab 2 (1.0–2.0 HCFT/day avg)", rate: "Rs 2,100.00/MMBTU", note: "" },
  { cat: "Unprotected Slab 3 (Above 2.0 HCFT/day avg)", rate: "Rs 2,750.00/MMBTU", note: "High consumers" },
  { cat: "Commercial", rate: "Rs 3,900.00/MMBTU", note: "" },
  { cat: "Industrial (SNGPL RLNG)", rate: "Rs 4,300.00+/MMBTU", note: "Market-rate RLNG" },
];

const faqs = [
  { q: "How do I check my SNGPL gas bill online in March 2026?", a: "Visit sngpl.com.pk and click Customer Services → View/Print Bill. Enter your 11-digit SNGPL consumer number (printed on any previous gas bill) and click Submit. Your complete SNGPL bill for March 2026 appears instantly — showing amount due, due date, consumption in MMBTU, meter readings, and all charges. You can also use the SNGPL app on Android or iOS for the same result." },
  { q: "Where do I find my SNGPL 11-digit consumer number?", a: "Your SNGPL consumer number is an 11-digit number printed prominently on the top section of every SNGPL gas bill — usually on the right side near your name and address. Unlike electricity bills which have 14-digit reference numbers, SNGPL uses 11 digits. If you have lost all bills, call SNGPL helpline 1199 with your CNIC and registered address to retrieve your consumer number." },
  { q: "What is the SNGPL helpline and how do I contact them?", a: "SNGPL helpline is 1199 — available 24 hours a day, 7 days a week. Call 1199 for gas leakage emergencies (top priority), billing disputes, new connection queries, load transfer applications, pressure complaints, and gas theft reporting. For non-emergency billing issues, calling between 9 AM and 11 AM on weekdays connects faster." },
  { q: "What areas does SNGPL supply gas to?", a: "SNGPL supplies natural gas and RLNG (imported liquefied natural gas) to Punjab, Khyber Pakhtunkhwa, Islamabad Capital Territory, and Azad Jammu & Kashmir. This includes all major Punjab cities (Lahore, Faisalabad, Multan, Rawalpindi, Gujranwala, Sialkot, Bahawalpur), all major KPK cities (Peshawar, Mardan, Abbottabad, Swat), Islamabad, and parts of AJK. SSGC, not SNGPL, supplies Karachi, Sindh, and Balochistan." },
  { q: "What is the difference between SNGPL and SSGC?", a: "SNGPL (Sui Northern Gas Pipelines Limited) supplies gas to Punjab, KPK, ICT, and AJK — the northern half of Pakistan. SSGC (Sui Southern Gas Company) supplies Karachi, interior Sindh, and Balochistan — the southern half. If you live in Lahore, Islamabad, Peshawar, or Multan, your gas company is SNGPL. If you live in Karachi, Hyderabad, Quetta, or Sukkur, your gas company is SSGC." },
  { q: "What is MMBTU on my SNGPL bill?", a: "MMBTU stands for Million British Thermal Units — the unit SNGPL uses to measure your gas consumption. Your gas meter records consumption in HCFT (Hundred Cubic Feet). SNGPL converts this to MMBTU for billing. 1 MMBTU is approximately equal to 10.03 HCFT of natural gas. Your bill shows both the HCFT meter reading and the MMBTU equivalent on which charges are calculated." },
  { q: "What is the difference between Protected and Unprotected gas consumers on SNGPL?", a: "SNGPL classifies domestic consumers as Protected or Unprotected based on average daily gas consumption. Protected consumers (average ≤0.5 HCFT per day — roughly 15 HCFT per month) pay the highly subsidized rate of Rs 400/MMBTU. Unprotected consumers face slab rates starting at Rs 1,597/MMBTU for the first slab. The difference is enormous — Protected consumers pay 75% less than even the lowest Unprotected slab. Monitor your monthly consumption to stay within the Protected threshold." },
  { q: "How do I pay my SNGPL gas bill online?", a: "Pay through JazzCash, Easypaisa, or any bank mobile app. Open the app, go to Bill Payments, select Gas, choose SNGPL, enter your 11-digit consumer number, verify the amount, and confirm. You receive an SMS confirmation instantly. All major banks (HBL, MCB, UBL, Meezan, Allied Bank, Bank Alfalah) support SNGPL payments. You can also pay at any SNGPL regional office by cash or online." },
  { q: "Why is my SNGPL gas bill so high in winter?", a: "SNGPL winter bills are high for two main reasons: (1) Gas usage for heating (room heaters, geysers) spikes 200–400% compared to summer; (2) Winter demand across Punjab and KPK strains SNGPL's supply, requiring more expensive imported RLNG — which carries higher charges per MMBTU than domestically produced natural gas. Protected consumers' subsidized rate stays constant, but Unprotected consumers feel the full impact. Reduce heating use, insulate your home, and use gas only for cooking and controlled heating." },
  { q: "How do I report a gas leakage to SNGPL?", a: "Call SNGPL emergency helpline 1199 immediately. Before calling: turn off all gas appliances, open all windows and doors to ventilate, do not use any electrical switches, do not use a mobile phone near the gas source, and evacuate the building if the smell is strong. SNGPL has 24/7 emergency response teams in all major cities. Response time in major cities is typically 30 to 60 minutes." },
  { q: "How do I apply for a new SNGPL gas connection?", a: "Apply online at sngpl.com.pk under New Connection, or visit your nearest SNGPL regional office in Lahore, Islamabad, Faisalabad, Multan, Peshawar, or your city. Submit your CNIC, property ownership or tenancy documents, and a site map. Connection fees vary by distance from the main pipeline. Connections near existing infrastructure take 30–90 days. Areas needing new pipeline work can take 6–24 months." },
  { q: "How do I download my SNGPL gas bill as PDF?", a: "Visit sngpl.com.pk → Customer Services → View/Print Bill → enter your 11-digit consumer number → Submit. When the bill appears, press Ctrl+P (or right-click → Print) and select Save as PDF in the printer destination. Your SNGPL bill saves as a PDF on your device. You can also email it to yourself from the SNGPL portal." },
  { q: "What is RLNG on my SNGPL bill?", a: "RLNG (Re-Gasified Liquefied Natural Gas) is imported LNG from Qatar and other Gulf states that SNGPL mixes into its pipeline network during periods of high domestic demand. RLNG is more expensive than domestically produced natural gas — it carries GIDC (Gas Infrastructure Development Cess) and higher commodity costs. Consumers on the RLNG allocation (usually industrial and commercial) pay higher RLNG rates. Domestic consumers are charged domestic gas rates that OGRA sets separately." },
];
