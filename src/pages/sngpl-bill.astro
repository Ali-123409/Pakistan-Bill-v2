<script>
  function checkSNGPL() {
    const input = (document.getElementById('sngpl-input') as HTMLInputElement);
    const err = document.getElementById('sngpl-error');
    const val = input.value.trim();
    if (val.length !== 11) {
      err!.style.display = 'block';
      err!.textContent = 'Please enter a valid 11-digit SNGPL consumer number.';
      return;
    }
    err!.style.display = 'none';
    window.open(`https://www.sngpl.com.pk/index.php?q=bill-view&type=consumer_no&no=${val}`, '_blank');
  }
</script>
