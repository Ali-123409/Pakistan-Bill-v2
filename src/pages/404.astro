---
import BaseLayout from '../layouts/BaseLayout.astro';
const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Page Not Found — PakistanBill.online",
  "url": "https://pakistanbill.online/404/",
  "isPartOf": {"@id": "https://pakistanbill.online/#website"}
};
---
<BaseLayout
  title="Page Not Found — PakistanBill.online"
  description="The page you are looking for does not exist. Check your URL or find your bill checker from the list below."
  canonical="/404/"
  schema={schema}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <div class="text-8xl mb-6">⚡</div>
    <h1 class="text-4xl font-heading font-bold text-neutral-900 mb-4">Page Not Found</h1>
    <p class="text-lg text-neutral-600 mb-8">The page you're looking for doesn't exist. Maybe you were looking for one of these bill checkers?</p>

    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-10 text-left">
      {[
        ["⚡ LESCO Bill","/lesco-bill/"],["⚡ MEPCO Bill","/mepco-bill/"],
        ["⚡ GEPCO Bill","/gepco-bill/"],["⚡ FESCO Bill","/fesco-bill/"],
        ["⚡ IESCO Bill","/iesco-bill/"],["⚡ PESCO Bill","/pesco-bill/"],
        ["⚡ K-Electric","/k-electric-bill/"],["🔥 SNGPL Gas","/sngpl-bill/"],
        ["🔥 SSGC Gas","/ssgc-bill/"],["📞 PTCL Bill","/ptcl-bill/"],
        ["💧 WASA Lahore","/wasa-lahore-bill/"],["🧮 Calculator","/electricity-bill-calculator/"],
      ].map((item) => (
        <a href={item[1]} class="bg-white border border-neutral-200 rounded-xl px-4 py-3 text-sm font-semibold text-neutral-700 hover:border-primary-400 hover:text-primary-700 transition-all">{item[0]}</a>
      ))}
    </div>

    <a href="/" class="inline-block bg-primary-700 text-white px-8 py-3 rounded-xl font-bold hover:bg-primary-800 transition-colors">← Go to Homepage</a>
  </div>
</BaseLayout>
