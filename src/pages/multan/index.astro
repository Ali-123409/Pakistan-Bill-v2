---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = [{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://pakistanbill.online/multan/#webpage",
  "url": "https://pakistanbill.online/multan/",
  "name": "Utility Bill Check Multan — Electricity, Gas & Water Bills Online",
  "description": "Check all utility bills in Multan: MEPCO electricity bill, SNGPL gas bill, and WASA Multan water bill. Find Multan utility office addresses, helplines, and bill payment guides.",
  "isPartOf": {"@id": "https://pakistanbill.online/#website"},
  "dateModified": "2026-03-11"
},
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"How to check electricity bill in Multan?","acceptedAnswer":{"@type":"Answer","text":"Residents of Multan get electricity from MEPCO. Check your Multan electricity bill at pakistanbill.online/mepco-bill/ by entering your 14-digit reference number. Free, instant, no login."}},
      {"@type":"Question","name":"How to check gas bill in Multan?","acceptedAnswer":{"@type":"Answer","text":"Multan gas consumers use SNGPL. Check your Multan gas bill at pakistanbill.online/sngpl-bill/ by entering your consumer number. For complaints call 1199."}},
  ]
}];
---
<BaseLayout
  title="Bill Check Multan 2026 — MEPCO, SNGPL, WASA Multan Online"
  description="Check all utility bills in Multan: MEPCO electricity bill, SNGPL gas bill, WASA Multan. Find helplines, office addresses, and how to pay online. Updated March 2026."
  canonical="/multan/"
  schema={schema}
  lastmod="2026-03-11"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium">Multan Utility Bills</span>
      </nav>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-2">Utility Bill Check — Multan, Punjab</h1>
    <p class="text-lg text-neutral-600 mb-8">Multan (2 million residents) gets electricity from <strong>MEPCO</strong>, gas from <strong>SNGPL</strong>, and water from <strong>WASA Multan</strong>. Check any Multan utility bill below instantly.</p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
      <a href="/mepco-bill/" class="bg-white border-2 border-primary-200 rounded-2xl p-5 hover:border-primary-500 transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">MEPCO Electricity</h2>
        <p class="text-sm text-neutral-500 mb-3">Check Multan electricity bill by 14-digit reference number</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check MEPCO Bill →</span>
      </a>
      <a href="/sngpl-bill/" class="bg-white border-2 border-orange-200 rounded-2xl p-5 hover:border-orange-500 transition-all group">
        <div class="text-3xl mb-3">🔥</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">SNGPL Gas</h2>
        <p class="text-sm text-neutral-500 mb-3">Check Multan gas bill by consumer number</p>
        <span class="text-orange-600 font-semibold text-sm group-hover:underline">Check SNGPL Bill →</span>
      </a>
      <a href="/sngpl-bill/" class="bg-white border-2 border-blue-200 rounded-2xl p-5 hover:border-blue-500 transition-all group">
        <div class="text-3xl mb-3">💧</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">WASA Multan</h2>
        <p class="text-sm text-neutral-500 mb-3">Check Multan water bill online</p>
        <span class="text-blue-600 font-semibold text-sm group-hover:underline">Check Water Bill →</span>
      </a>
    </div>

    <div class="bg-primary-50 border border-primary-200 rounded-2xl p-5 mb-8">
      <h2 class="font-bold text-primary-800 mb-2">⚡ Fast: Check Your Multan Bill Right Now</h2>
      <p class="text-sm text-primary-700 mb-3">Use our dashboard to check any Multan utility bill — electricity, gas, or telecom — without switching pages.</p>
      <a href="/dashboard/" class="inline-block bg-primary-700 text-white px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-primary-800 transition-colors">Open Bill Dashboard →</a>
    </div>

    <h2 class="text-xl font-heading font-bold mb-4">How to Pay Utility Bills in Multan</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
      {[
        ["JazzCash App","Bill Payments → Electricity/Gas → Enter ref/consumer number"],
        ["EasyPaisa","Bill Payments → Select utility → Enter account number"],
        ["HBL / MCB / Meezan","Bank app → Bill Payments → Select provider"],
        ["1-Link ATM","Bill Payment → Select utility biller code → Enter number"],
        ["Utility Office","Walk-in payment at nearest MEPCO / SNGPL office in Multan"],
        ["QR Code on Bill","Scan QR printed on your Multan bill with any bank app"],
      ].map((item) => (
        <div class="bg-white border border-neutral-200 rounded-xl p-3">
          <h3 class="font-semibold text-neutral-800 text-sm">{item[0]}</h3>
          <p class="text-xs text-neutral-500 mt-1">{item[1]}</p>
        </div>
      ))}
    </div>

    <h2 class="text-xl font-heading font-bold mb-4">Frequently Asked Questions — Multan Utility Bills</h2>
    <div class="space-y-3">
      {[
        { q: `How to check electricity bill in Multan?`, a: `Multan residents receive electricity from MEPCO. Enter your 14-digit MEPCO reference number at our MEPCO bill checker — pakistanbill.online/mepco-bill/. Your bill appears instantly, free, no login required.` }},
        { q: `How to check gas bill in Multan?`, a: `Multan consumers use SNGPL for gas supply. Visit pakistanbill.online/sngpl-bill/ and enter your consumer number. For complaints or emergencies call SNGPL helpline 1199.` }},
        { q: `How to pay electricity bill online in Multan?`, a: `Pay your Multan MEPCO electricity bill through JazzCash, EasyPaisa, HBL, MCB, Meezan bank apps, or scan the QR code on your bill. All payment apps support MEPCO bill payments using your 14-digit reference number.` }},
        { q: `What is the grace period for electricity bill in Multan?`, a: `MEPCO gives 7 days after the due date to pay without a 10% late payment surcharge. Pay before your due date to avoid extra charges. Check your due date using our MEPCO bill checker above.` }},
        { q: `How to download duplicate electricity bill in Multan?`, a: `Check your MEPCO bill at pakistanbill.online/mepco-bill/, then click Download PDF. Your Multan electricity duplicate bill downloads instantly. You can print it at any shop or pay using the bill number.` }},
      ].map((faq) => (
        <details class="faq-item">
          <summary class="faq-question">{faq.q}</summary>
          <div class="px-4 pb-4 text-sm text-neutral-600">{faq.a}</div>
        </details>
      ))}
    </div>
  </div>
<p style="margin:1rem 0;padding:1rem;background:#f0fdf4;border-left:4px solid #16a34a;border-radius:0 8px 8px 0;font-size:0.9rem;line-height:1.7;">PakistanBill.online is <strong>Pakistan's only platform</strong> covering all utility bills in Multan and every other city in Pakistan. Check all Multan bills here: <a href="/mepco-bill/">MEPCO electricity</a> | <a href="/sngpl-bill/">SNGPL gas</a> | <a href="/ptcl-bill/">PTCL telecom</a> | <a href="/electricity-bill-calculator/">electricity bill calculator</a> | <a href="/dashboard/">all bills dashboard</a>. Also check nearby cities: <a href="/bahawalpur/">Bahawalpur</a> | <a href="/faisalabad/">Faisalabad</a> | <a href="/lahore/">Lahore</a>.</p>
</BaseLayout>
