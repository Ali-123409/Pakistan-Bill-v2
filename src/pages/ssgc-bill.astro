<script>
  function checkSSGC() {
    const input = (document.getElementById('ssgc-input') as HTMLInputElement);
    const err = document.getElementById('ssgc-error');
    const val = input.value.trim();
    if (val.length !== 10) {
      err!.style.display = 'block';
      err!.textContent = 'Please enter a valid 10-digit SSGC consumer number.';
      return;
    }
    err!.style.display = 'none';
    window.open(`https://www.ssgc.com.pk/bill/?consumer=${val}`, '_blank');
  }
</script>
