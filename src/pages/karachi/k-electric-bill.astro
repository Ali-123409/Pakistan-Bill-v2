---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://pakistanbill.online/karachi/k-electric-bill/#webpage",
    "url": "https://pakistanbill.online/karachi/k-electric-bill/",
    "name": "K-Electric Bill Karachi \u2014 Check Karachi Electricity Bill Online",
    "description": "Check your K-Electric electricity bill in Karachi, Sindh. Enter your 13-digit reference number to view, download, and print your Karachi electricity bill free.",
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Home","item":"https://pakistanbill.online/"},
        {"@type":"ListItem","position":2,"name":"Karachi","item":"https://pakistanbill.online/karachi/"},
        {"@type":"ListItem","position":3,"name":"K-Electric Bill Karachi","item":"https://pakistanbill.online/karachi/k-electric-bill/"}
      ]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type":"Question","name":"How to check K-Electric bill in Karachi?","acceptedAnswer":{"@type":"Answer","text":"Go to pakistanbill.online/karachi/k-electric-bill/ or use our main K-Electric checker. Enter your 13-digit K-Electric reference number. Your Karachi electricity bill loads instantly \u2014 free, no login."}},
      {"@type":"Question","name":"What is the K-Electric helpline in Karachi?","acceptedAnswer":{"@type":"Answer","text":"Call K-Electric helpline 118 for billing complaints in Karachi, Sindh. You can also SMS your reference number to 8118 to receive your bill details."}},
      {"@type":"Question","name":"How to pay K-Electric bill in Karachi?","acceptedAnswer":{"@type":"Answer","text":"Pay your Karachi K-Electric electricity bill through JazzCash, EasyPaisa, HBL Mobile, Meezan Bank, or any bank app. Select Bill Payments \u2192 Electricity \u2192 K-Electric \u2192 enter 13-digit reference number."}}
    ]
  }
];
---
<BaseLayout
  title="K-Electric Bill Karachi \u2014 Check Karachi Electricity Bill Online"
  description="Check K-Electric electricity bill in Karachi, Sindh. Enter 13-digit reference number \u2014 view, download PDF, print free. Pakistan\'s fastest bill checker."
  canonical="/karachi/k-electric-bill/"
  schema={schema}
  lastmod="2026-03-13"
>
  <!-- Breadcrumb -->
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <a href="/karachi/" class="hover:text-primary-600">Karachi</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium">K-Electric Bill</span>
      </nav>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-3">K-Electric Bill Karachi \u2014 Check Online</h1>
    <p class="text-neutral-600 mb-8">K-Electric supplies electricity to <strong>Karachi, Sindh</strong>. Use our checker below to instantly view your Karachi electricity bill. Free, no login, no registration.</p>

    <!-- Redirect to main checker with note -->
    <div class="bg-primary-50 border border-primary-200 rounded-2xl p-6 mb-8 text-center">
      <div class="text-4xl mb-3">⚡</div>
      <h2 class="font-bold text-xl text-primary-900 mb-2">Check Your K-Electric Bill Now</h2>
      <p class="text-primary-700 mb-4 text-sm">Enter your 13-digit K-Electric reference number on the bill checker page.</p>
      <a href="/k-electric-bill/" class="inline-block bg-primary-700 text-white px-8 py-3 rounded-xl font-bold text-lg hover:bg-primary-800 transition-colors">
        Open K-Electric Bill Checker \u2192
      </a>
    </div>

    <!-- Info grid -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
      {[
        ["📋", "Reference Number", "13-digit digits — top-right of your bill, labeled \"Ref. No.\""],
        ["📍", "Coverage", "Karachi and surrounding districts in Sindh"],
        ["📞", "Helpline", "118 (free) — available 24/7 for billing complaints"],
      ].map((item) => (
        <div class="bg-white border border-neutral-200 rounded-xl p-4 text-sm">
          <div class="text-2xl mb-2">{item[0]}</div>
          <div class="font-semibold text-neutral-900 mb-1">{item[1]}</div>
          <div class="text-neutral-500">{item[2]}</div>
        </div>
      ))}
    </div>

    <!-- Steps -->
    <h2 class="text-xl font-heading font-bold text-neutral-900 mb-4">How to Check K-Electric Bill in Karachi</h2>
    <ol class="space-y-3 mb-8">
      {[
        ["Find your reference number", "Look at the top-right section of your K-Electric bill for a 13-digit number labeled \"Ref. No.\""],
        ["Open the K-Electric bill checker", "Click the button above to go to our K-Electric checker page."],
        ["Enter reference number", "Type your 13-digit-digit reference number and click Check Bill."],
        ["View and download", "Your Karachi electricity bill loads instantly. Click Download PDF to save a copy."],
      ].map((item, i) => (
        <li class="flex gap-4 bg-white border border-neutral-200 rounded-xl p-4">
          <span class="w-8 h-8 bg-primary-700 text-white rounded-full flex items-center justify-center font-bold flex-shrink-0 text-sm">{i+1}</span>
          <div>
            <div class="font-semibold text-neutral-900 text-sm">{item[1]}</div>
            <div class="text-neutral-500 text-sm">{item[2]}</div>
          </div>
        </li>
      ))}
    </ol>

    <!-- FAQ -->
    <h2 class="text-xl font-heading font-bold text-neutral-900 mb-4">Frequently Asked Questions</h2>
    <div class="space-y-3 mb-8">
      {[
        { q: "How to check K-Electric bill in Karachi?", a: "Visit pakistanbill.online/k-electric-bill/ and enter your 13-digit K-Electric reference number. Your Karachi electricity bill appears instantly." },
        { q: "What is K-Electric helpline number in Karachi?", a: "Call K-Electric helpline 118 for billing issues in Karachi, Sindh. You can also SMS your 14-digit reference number to 8118." },
        { q: "How to pay K-Electric bill in Karachi?", a: "Pay through JazzCash, EasyPaisa, HBL Mobile, or any bank app. Select Bill Payments → Electricity → K-Electric → enter 13-digit reference number → confirm." },
      ].map((faq) => (
        <details class="faq-item">
          <summary class="faq-question">{faq.q}</summary>
          <div class="px-4 pb-4 text-sm text-neutral-600">{faq.a}</div>
        </details>
      ))}
    </div>

    <!-- Related links -->
    <div class="border-t border-neutral-200 pt-6">
      <h2 class="font-bold text-neutral-800 mb-3">Related Pages</h2>
      <div class="flex flex-wrap gap-2">
        <a href="/k-electric-bill/" class="text-sm bg-primary-50 border border-primary-200 rounded-lg px-3 py-2 text-primary-700 font-semibold hover:underline">K-Electric Bill Checker →</a>
        <a href="/karachi/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-700 hover:underline">Karachi Utility Bills →</a>
        <a href="/electricity/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-700 hover:underline">All Electricity Bills →</a>
        <a href="/electricity-bill-calculator/" class="text-sm bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-700 hover:underline">Bill Calculator →</a>
      </div>
    </div>
  </div>
</BaseLayout>
