---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://pakistanbill.online/abbottabad/#webpage",
    "url": "https://pakistanbill.online/abbottabad/",
    "name": "Utility Bill Check Abbottabad 2026 — Electricity, Gas & Bills Online",
    "description": "Check all utility bills in Abbottabad, KPK: PESCO electricity bill and SNGPL gas bill. Helplines, office addresses, and online payment guide.",
    "isPartOf": {"@id": "https://pakistanbill.online/#website"},
    "dateModified": "2026-03-11"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{"@type":"Question","name":"How to check electricity bill in Abbottabad?","acceptedAnswer":{"@type":"Answer","text":"Abbottabad electricity is supplied by PESCO. Enter your 14-digit reference number at pakistanbill.online/pesco-bill/. PESCO covers all settled KPK districts including Abbottabad, Haripur, Mansehra, and Hazara division."}},
      {"@type":"Question","name":"How to check gas bill in Abbottabad?","acceptedAnswer":{"@type":"Answer","text":"Abbottabad gas is supplied by SNGPL. Enter your 11-digit consumer number at pakistanbill.online/sngpl-bill/. Abbottabad has good natural gas network coverage."}},
      {"@type":"Question","name":"Does Abbottabad use PESCO?","acceptedAnswer":{"@type":"Answer","text":"Yes. Abbottabad and all of Hazara division (Abbottabad, Haripur, Mansehra, Battagram, Kohistan) are served by PESCO. TESCO only covers the seven Merged Tribal Districts — Abbottabad is a settled KPK district under PESCO."}},
      {"@type":"Question","name":"PESCO helpline for Abbottabad?","acceptedAnswer":{"@type":"Answer","text":"PESCO helpline is 118 (24/7) and 091-9213205. For Abbottabad-specific matters visit the PESCO Abbottabad subdivision office."}},
      {"@type":"Question","name":"How to pay PESCO bill in Abbottabad?","acceptedAnswer":{"@type":"Answer","text":"Pay via JazzCash, EasyPaisa, or any bank app. Select Electricity → PESCO → enter your 14-digit reference number."}}]
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "PakistanBill.online — Abbottabad Utility Bill Checker",
    "description": "Free online utility bill checker for Abbottabad, KPK. Check electricity, gas and water bills instantly.",
    "url": "https://pakistanbill.online/abbottabad/",
    "areaServed": {"@type": "City", "name": "Abbottabad", "containedInPlace": {"@type": "State", "name": "KPK"},
    "telephone": "+92-992-383601",
    "address": {"@type": "PostalAddress", "addressLocality": "Abbottabad", "addressRegion": "KPK", "addressCountry": "PK"},
    "openingHours": "Mo-Su 00:00-24:00",
    "priceRange": "Free"
  }
];
---
<BaseLayout
  title="Bill Check Abbottabad 2026 — PESCO, SNGPL Online | PakistanBill"
  description="Check all utility bills in Abbottabad, KPK: PESCO electricity, SNGPL gas. Helplines, payment guides. Updated March 2026."
  canonical="/abbottabad/"
  schema={schema}
  lastmod="2026-03-11"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium">Abbottabad Utility Bills</span>
      </nav>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-2">Utility Bill Check — Abbottabad, KPK</h1>
    <p class="text-lg text-neutral-600 mb-2">Abbottabad (0.18 million) gets electricity from <strong>PESCO</strong> and gas from <strong>SNGPL</strong>. Check any Abbottabad utility bill below instantly.</p>
    <p class="text-sm text-neutral-400 italic mb-8">Abbottabad ka bijli ka bill PESCO se check karein — Check, download, aur PDF save karein. Bilkul free.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
      <a href="/pesco-bill/" class="bg-white border-2 border-primary-200 rounded-2xl p-5 hover:border-primary-500 transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">PESCO Electricity</h2>
        <p class="text-sm text-neutral-500 mb-3">Check Abbottabad electricity bill by 14-digit reference number — free, instant</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check PESCO Bill →</span>
      </a>
      <a href="/sngpl-bill/" class="bg-white border-2 border-orange-200 rounded-2xl p-5 hover:border-orange-500 transition-all group">
        <div class="text-3xl mb-3">🔥</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">SNGPL Gas</h2>
        <p class="text-sm text-neutral-500 mb-3">Check Abbottabad gas bill by consumer number</p>
        <span class="text-orange-600 font-semibold text-sm group-hover:underline">Check SNGPL Bill →</span>
      </a>
    </div>

    <div class="bg-primary-50 border border-primary-200 rounded-2xl p-5 mb-8">
      <h2 class="font-bold text-primary-800 mb-1">⚡ Check Any Abbottabad Utility Bill — All in One Place</h2>
      <p class="text-sm text-primary-700 mb-3">Use our universal dashboard to toggle between electricity, gas, and telecom bills without reloading.</p>
      <a href="/dashboard/" class="inline-block bg-primary-700 text-white px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-primary-800 transition-colors">Open Bill Dashboard →</a>
    </div>

    <h2 class="text-xl font-heading font-bold mb-4">How to Pay Utility Bills in Abbottabad</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
      {[
        ["JazzCash App","Bill Payments → Electricity/Gas → Enter reference/consumer number"],
        ["EasyPaisa","Bill Payments → Select utility → Enter account number"],
        ["HBL / MCB / Meezan","Bank app → Bill Payments → Select provider"],
        ["1-Link ATM","Bill Payment → Select utility biller code → Enter number"],
        ["Utility Office","Walk-in payment at nearest PESCO or SNGPL office in Abbottabad"],
        ["QR Code on Bill","Scan QR printed on your bill with any bank app — instant payment"],
      ].map((item) => (
        <div class="bg-white border border-neutral-200 rounded-xl p-3">
          <h3 class="font-semibold text-neutral-800 text-sm">{item[0]}</h3>
          <p class="text-xs text-neutral-500 mt-1">{item[1]}</p>
        </div>
      ))}
    </div>

    <h2 class="text-xl font-heading font-bold mb-4">FAQs — Abbottabad Utility Bills</h2>
    <div class="space-y-3 mb-10">
      {[{ q: `How to check electricity bill in Abbottabad?`, a: `Abbottabad electricity is supplied by PESCO. Enter your 14-digit reference number at pakistanbill.online/pesco-bill/. PESCO covers all settled KPK districts including Abbottabad, Haripur, Mansehra, and Hazara division.` },
        { q: `How to check gas bill in Abbottabad?`, a: `Abbottabad gas is supplied by SNGPL. Enter your 11-digit consumer number at pakistanbill.online/sngpl-bill/. Abbottabad has good natural gas network coverage.` },
        { q: `Does Abbottabad use PESCO?`, a: `Yes. Abbottabad and all of Hazara division (Abbottabad, Haripur, Mansehra, Battagram, Kohistan) are served by PESCO. TESCO only covers the seven Merged Tribal Districts — Abbottabad is a settled KPK district under PESCO.` },
        { q: `PESCO helpline for Abbottabad?`, a: `PESCO helpline is 118 (24/7) and 091-9213205. For Abbottabad-specific matters visit the PESCO Abbottabad subdivision office.` },
        { q: `How to pay PESCO bill in Abbottabad?`, a: `Pay via JazzCash, EasyPaisa, or any bank app. Select Electricity → PESCO → enter your 14-digit reference number.` }].map((faq) => (
        <details class="faq-item">
          <summary class="faq-question">{faq.q}</summary>
          <div class="px-4 pb-4 text-sm text-neutral-600">{faq.a}</div>
        </details>
      ))}
    </div>

    <!-- All providers crosslink -->
    <div class="bg-neutral-50 border border-neutral-200 rounded-2xl p-5">
      <h2 class="font-bold text-neutral-800 text-sm mb-3 uppercase tracking-wider">Check All Pakistan Utility Bills</h2>
      <div class="flex flex-wrap gap-2">
        {"LESCO,MEPCO,GEPCO,FESCO,IESCO,PESCO,HESCO,SEPCO,QESCO,TESCO,AJK,K-Electric,SNGPL Gas,SSGC Gas,PTCL,WASA Lahore,WASA RWP,WASA FSD".split(",").map(n => (
          <a href={`/${n.toLowerCase().replace(/ /g,"-").replace("k-electric","k-electric-bill").replace("sngpl-gas","sngpl-bill").replace("ssgc-gas","ssgc-bill").replace("wasa-lahore","wasa-lahore-bill").replace("wasa-rwp","wasa-rawalpindi-bill").replace("wasa-fsd","wasa-faisalabad-bill").replace(/^([a-z]+)$/, "$1-bill")}/`}
             class="text-xs font-semibold bg-white border border-neutral-200 rounded-md px-3 py-1.5 text-neutral-600 hover:text-primary-700 hover:border-primary-300 transition-colors">
            {n}
          </a>
        ))}
      </div>
    </div>
  </div>
<p style="margin:1rem 0;padding:1rem;background:#f0fdf4;border-left:4px solid #16a34a;border-radius:0 8px 8px 0;font-size:0.9rem;line-height:1.7;">PakistanBill.online is <strong>Pakistan's only platform</strong> covering all utility bills in Abbottabad and every other city in Pakistan. Check all Abbottabad bills here: <a href="/pesco-bill/">PESCO electricity</a> | <a href="/sngpl-bill/">SNGPL gas</a> | <a href="/ptcl-bill/">PTCL telecom</a> | <a href="/electricity-bill-calculator/">electricity bill calculator</a> | <a href="/dashboard/">all bills dashboard</a>. Also check nearby cities: <a href="/peshawar/">Peshawar</a> | <a href="/islamabad/">Islamabad</a> | <a href="/rawalpindi/">Rawalpindi</a>.</p>
</BaseLayout>
