---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = [{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://pakistanbill.online/islamabad/#webpage",
  "url": "https://pakistanbill.online/islamabad/",
  "name": "Utility Bill Check Islamabad — Electricity, Gas & Water Bills Online",
  "description": "Check all utility bills in Islamabad: IESCO electricity bill, SNGPL gas bill, and CDA Water water bill. Find Islamabad utility office addresses, helplines, and bill payment guides.",
  "isPartOf": {"@id": "https://pakistanbill.online/#website"},
  "dateModified": "2026-03-11"
},
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"How to check electricity bill in Islamabad?","acceptedAnswer":{"@type":"Answer","text":"Residents of Islamabad get electricity from IESCO. Check your Islamabad electricity bill at pakistanbill.online/iesco-bill/ by entering your 14-digit reference number. Free, instant, no login."}},
      {"@type":"Question","name":"How to check gas bill in Islamabad?","acceptedAnswer":{"@type":"Answer","text":"Islamabad gas consumers use SNGPL. Check your Islamabad gas bill at pakistanbill.online/sngpl-bill/ by entering your consumer number. For complaints call 1199."}},
  ]
}];
---
<BaseLayout
  title="Bill Check Islamabad 2026 — IESCO, SNGPL, CDA Water Online"
  description="Check all utility bills in Islamabad: IESCO electricity bill, SNGPL gas bill, CDA Water. Find helplines, office addresses, and how to pay online. Updated March 2026."
  canonical="/islamabad/"
  schema={schema}
  lastmod="2026-03-11"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium">Islamabad Utility Bills</span>
      </nav>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-2">Utility Bill Check — Islamabad, ICT</h1>
    <p class="text-lg text-neutral-600 mb-8">Islamabad (2.2 million residents) gets electricity from <strong>IESCO</strong>, gas from <strong>SNGPL</strong>, and water from <strong>CDA Water</strong>. Check any Islamabad utility bill below instantly.</p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
      <a href="/iesco-bill/" class="bg-white border-2 border-primary-200 rounded-2xl p-5 hover:border-primary-500 transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">IESCO Electricity</h2>
        <p class="text-sm text-neutral-500 mb-3">Check Islamabad electricity bill by 14-digit reference number</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check IESCO Bill →</span>
      </a>
      <a href="/sngpl-bill/" class="bg-white border-2 border-orange-200 rounded-2xl p-5 hover:border-orange-500 transition-all group">
        <div class="text-3xl mb-3">🔥</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">SNGPL Gas</h2>
        <p class="text-sm text-neutral-500 mb-3">Check Islamabad gas bill by consumer number</p>
        <span class="text-orange-600 font-semibold text-sm group-hover:underline">Check SNGPL Bill →</span>
      </a>
      <a href="/wasa-rawalpindi-bill/" class="bg-white border-2 border-blue-200 rounded-2xl p-5 hover:border-blue-500 transition-all group">
        <div class="text-3xl mb-3">💧</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">CDA Water</h2>
        <p class="text-sm text-neutral-500 mb-3">Check Islamabad water bill online</p>
        <span class="text-blue-600 font-semibold text-sm group-hover:underline">Check Water Bill →</span>
      </a>
    </div>

    <div class="bg-primary-50 border border-primary-200 rounded-2xl p-5 mb-8">
      <h2 class="font-bold text-primary-800 mb-2">⚡ Fast: Check Your Islamabad Bill Right Now</h2>
      <p class="text-sm text-primary-700 mb-3">Use our dashboard to check any Islamabad utility bill — electricity, gas, or telecom — without switching pages.</p>
      <a href="/dashboard/" class="inline-block bg-primary-700 text-white px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-primary-800 transition-colors">Open Bill Dashboard →</a>
    </div>

    <h2 class="text-xl font-heading font-bold mb-4">How to Pay Utility Bills in Islamabad</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
      {[
        ["JazzCash App","Bill Payments → Electricity/Gas → Enter ref/consumer number"],
        ["EasyPaisa","Bill Payments → Select utility → Enter account number"],
        ["HBL / MCB / Meezan","Bank app → Bill Payments → Select provider"],
        ["1-Link ATM","Bill Payment → Select utility biller code → Enter number"],
        ["Utility Office","Walk-in payment at nearest IESCO / SNGPL office in Islamabad"],
        ["QR Code on Bill","Scan QR printed on your Islamabad bill with any bank app"],
      ].map((item) => (
        <div class="bg-white border border-neutral-200 rounded-xl p-3">
          <h3 class="font-semibold text-neutral-800 text-sm">{item[0]}</h3>
          <p class="text-xs text-neutral-500 mt-1">{item[1]}</p>
        </div>
      ))}
    </div>

    <h2 class="text-xl font-heading font-bold mb-4">Frequently Asked Questions — Islamabad Utility Bills</h2>
    <div class="space-y-3">
      {[
        { q: `How to check electricity bill in Islamabad?`, a: `Islamabad residents receive electricity from IESCO. Enter your 14-digit IESCO reference number at our IESCO bill checker — pakistanbill.online/iesco-bill/. Your bill appears instantly, free, no login required.` }},
        { q: `How to check gas bill in Islamabad?`, a: `Islamabad consumers use SNGPL for gas supply. Visit pakistanbill.online/sngpl-bill/ and enter your consumer number. For complaints or emergencies call SNGPL helpline 1199.` }},
        { q: `How to pay electricity bill online in Islamabad?`, a: `Pay your Islamabad IESCO electricity bill through JazzCash, EasyPaisa, HBL, MCB, Meezan bank apps, or scan the QR code on your bill. All payment apps support IESCO bill payments using your 14-digit reference number.` }},
        { q: `What is the grace period for electricity bill in Islamabad?`, a: `IESCO gives 7 days after the due date to pay without a 10% late payment surcharge. Pay before your due date to avoid extra charges. Check your due date using our IESCO bill checker above.` }},
        { q: `How to download duplicate electricity bill in Islamabad?`, a: `Check your IESCO bill at pakistanbill.online/iesco-bill/, then click Download PDF. Your Islamabad electricity duplicate bill downloads instantly. You can print it at any shop or pay using the bill number.` }},
      ].map((faq) => (
        <details class="faq-item">
          <summary class="faq-question">{faq.q}</summary>
          <div class="px-4 pb-4 text-sm text-neutral-600">{faq.a}</div>
        </details>
      ))}
    </div>
  </div>
<p style="margin:1rem 0;padding:1rem;background:#f0fdf4;border-left:4px solid #16a34a;border-radius:0 8px 8px 0;font-size:0.9rem;line-height:1.7;">PakistanBill.online is <strong>Pakistan's only platform</strong> covering all utility bills in Islamabad and every other city in Pakistan. Check all Islamabad bills here: <a href="/iesco-bill/">IESCO electricity</a> | <a href="/sngpl-bill/">SNGPL gas</a> | <a href="/wasa-rawalpindi-bill/">WASA Rawalpindi water</a> | <a href="/ptcl-bill/">PTCL telecom</a> | <a href="/electricity-bill-calculator/">electricity bill calculator</a> | <a href="/dashboard/">all bills dashboard</a>. Also check nearby cities: <a href="/rawalpindi/">Rawalpindi</a> | <a href="/lahore/">Lahore</a> | <a href="/peshawar/">Peshawar</a>.</p>
</BaseLayout>
