<script>
  function checkWASAL() {
    const input = (document.getElementById('wasa-l-input') as HTMLInputElement);
    const err = document.getElementById('wasa-l-error');
    const val = input.value.trim();
    if (val.length !== 8) {
      err!.style.display = 'block';
      err!.textContent = 'Please enter a valid 8-digit WASA Lahore account number.';
      return;
    }
    err!.style.display = 'none';
    window.open(`https://wasa.punjab.gov.pk/online-services/view-bill?account=${val}`, '_blank');
  }
</script>
