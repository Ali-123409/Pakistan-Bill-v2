---
import BaseLayout from '../../layouts/BaseLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://pakistanbill.online/sukkur/#webpage",
    "url": "https://pakistanbill.online/sukkur/",
    "name": "Utility Bill Check Sukkur 2026 — Electricity, Gas & Bills Online",
    "description": "Check all utility bills in Sukkur, Sindh: SEPCO electricity bill and SSGC gas bill. Helplines, office addresses, and online payment guide.",
    "isPartOf": {"@id": "https://pakistanbill.online/#website"},
    "dateModified": "2026-03-11"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{"@type":"Question","name":"How to check electricity bill in Sukkur?","acceptedAnswer":{"@type":"Answer","text":"Sukkur electricity consumers use SEPCO. Enter your 14-digit SEPCO reference number at pakistanbill.online/sepco-bill/. Free, no login, instant result."}},
      {"@type":"Question","name":"How to check gas bill in Sukkur?","acceptedAnswer":{"@type":"Answer","text":"Sukkur gas is supplied by SSGC. Enter your 10-digit consumer number at pakistanbill.online/ssgc-bill/. SSGC helpline: 1199."}},
      {"@type":"Question","name":"What is SEPCO helpline?","acceptedAnswer":{"@type":"Answer","text":"SEPCO helpline is 118 (24/7) and 071-5633605 (Sukkur office). Call for billing disputes, outages, and new connections."}},
      {"@type":"Question","name":"How to pay SEPCO bill online in Sukkur?","acceptedAnswer":{"@type":"Answer","text":"Pay SEPCO bill via JazzCash, EasyPaisa, or any bank mobile app. Select Electricity → SEPCO → enter 14-digit reference number."}},
      {"@type":"Question","name":"What area does SEPCO cover?","acceptedAnswer":{"@type":"Answer","text":"SEPCO covers Sukkur, Larkana, Khairpur, Ghotki, Jacobabad, Kashmore, and all of upper Sindh. It also covers parts of Jafarabad district in Balochistan."}}]
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "PakistanBill.online — Sukkur Utility Bill Checker",
    "description": "Free online utility bill checker for Sukkur, Sindh. Check electricity, gas and water bills instantly.",
    "url": "https://pakistanbill.online/sukkur/",
    "areaServed": {"@type": "City", "name": "Sukkur", "containedInPlace": {"@type": "State", "name": "Sindh"},
    "telephone": "+92-71-5633605",
    "address": {"@type": "PostalAddress", "addressLocality": "Sukkur", "addressRegion": "Sindh", "addressCountry": "PK"},
    "openingHours": "Mo-Su 00:00-24:00",
    "priceRange": "Free"
  }
];
---
<BaseLayout
  title="Bill Check Sukkur 2026 — SEPCO, SSGC Online | PakistanBill"
  description="Check all utility bills in Sukkur, Sindh: SEPCO electricity, SSGC gas. Helplines, payment guides. Updated March 2026."
  canonical="/sukkur/"
  schema={schema}
  lastmod="2026-03-11"
>
  <div class="bg-neutral-100 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2">
      <nav aria-label="Breadcrumb" class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-primary-600">Home</a>
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <span class="text-neutral-800 font-medium">Sukkur Utility Bills</span>
      </nav>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <h1 class="text-3xl font-heading font-bold text-neutral-900 mb-2">Utility Bill Check — Sukkur, Sindh</h1>
    <p class="text-lg text-neutral-600 mb-2">Sukkur (0.6 million) gets electricity from <strong>SEPCO</strong> and gas from <strong>SSGC</strong>. Check any Sukkur utility bill below instantly.</p>
    <p class="text-sm text-neutral-400 italic mb-8">Sukkur ka bijli ka bill SEPCO se check karein — Check, download, aur PDF save karein. Bilkul free.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
      <a href="/sepco-bill/" class="bg-white border-2 border-primary-200 rounded-2xl p-5 hover:border-primary-500 transition-all group">
        <div class="text-3xl mb-3">⚡</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">SEPCO Electricity</h2>
        <p class="text-sm text-neutral-500 mb-3">Check Sukkur electricity bill by 14-digit reference number — free, instant</p>
        <span class="text-primary-600 font-semibold text-sm group-hover:underline">Check SEPCO Bill →</span>
      </a>
      <a href="/ssgc-bill/" class="bg-white border-2 border-orange-200 rounded-2xl p-5 hover:border-orange-500 transition-all group">
        <div class="text-3xl mb-3">🔥</div>
        <h2 class="font-heading font-bold text-lg text-neutral-900 mb-1">SSGC Gas</h2>
        <p class="text-sm text-neutral-500 mb-3">Check Sukkur gas bill by consumer number</p>
        <span class="text-orange-600 font-semibold text-sm group-hover:underline">Check SSGC Bill →</span>
      </a>
    </div>

    <div class="bg-primary-50 border border-primary-200 rounded-2xl p-5 mb-8">
      <h2 class="font-bold text-primary-800 mb-1">⚡ Check Any Sukkur Utility Bill — All in One Place</h2>
      <p class="text-sm text-primary-700 mb-3">Use our universal dashboard to toggle between electricity, gas, and telecom bills without reloading.</p>
      <a href="/dashboard/" class="inline-block bg-primary-700 text-white px-5 py-2.5 rounded-lg font-semibold text-sm hover:bg-primary-800 transition-colors">Open Bill Dashboard →</a>
    </div>

    <h2 class="text-xl font-heading font-bold mb-4">How to Pay Utility Bills in Sukkur</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-8">
      {[
        ["JazzCash App","Bill Payments → Electricity/Gas → Enter reference/consumer number"],
        ["EasyPaisa","Bill Payments → Select utility → Enter account number"],
        ["HBL / MCB / Meezan","Bank app → Bill Payments → Select provider"],
        ["1-Link ATM","Bill Payment → Select utility biller code → Enter number"],
        ["Utility Office","Walk-in payment at nearest SEPCO or SSGC office in Sukkur"],
        ["QR Code on Bill","Scan QR printed on your bill with any bank app — instant payment"],
      ].map((item) => (
        <div class="bg-white border border-neutral-200 rounded-xl p-3">
          <h3 class="font-semibold text-neutral-800 text-sm">{item[0]}</h3>
          <p class="text-xs text-neutral-500 mt-1">{item[1]}</p>
        </div>
      ))}
    </div>

    <h2 class="text-xl font-heading font-bold mb-4">FAQs — Sukkur Utility Bills</h2>
    <div class="space-y-3 mb-10">
      {[{ q: `How to check electricity bill in Sukkur?`, a: `Sukkur electricity consumers use SEPCO. Enter your 14-digit SEPCO reference number at pakistanbill.online/sepco-bill/. Free, no login, instant result.` },
        { q: `How to check gas bill in Sukkur?`, a: `Sukkur gas is supplied by SSGC. Enter your 10-digit consumer number at pakistanbill.online/ssgc-bill/. SSGC helpline: 1199.` },
        { q: `What is SEPCO helpline?`, a: `SEPCO helpline is 118 (24/7) and 071-5633605 (Sukkur office). Call for billing disputes, outages, and new connections.` },
        { q: `How to pay SEPCO bill online in Sukkur?`, a: `Pay SEPCO bill via JazzCash, EasyPaisa, or any bank mobile app. Select Electricity → SEPCO → enter 14-digit reference number.` },
        { q: `What area does SEPCO cover?`, a: `SEPCO covers Sukkur, Larkana, Khairpur, Ghotki, Jacobabad, Kashmore, and all of upper Sindh. It also covers parts of Jafarabad district in Balochistan.` }].map((faq) => (
        <details class="faq-item">
          <summary class="faq-question">{faq.q}</summary>
          <div class="px-4 pb-4 text-sm text-neutral-600">{faq.a}</div>
        </details>
      ))}
    </div>

    <!-- All providers crosslink -->
    <div class="bg-neutral-50 border border-neutral-200 rounded-2xl p-5">
      <h2 class="font-bold text-neutral-800 text-sm mb-3 uppercase tracking-wider">Check All Pakistan Utility Bills</h2>
      <div class="flex flex-wrap gap-2">
        {"LESCO,MEPCO,GEPCO,FESCO,IESCO,PESCO,HESCO,SEPCO,QESCO,TESCO,AJK,K-Electric,SNGPL Gas,SSGC Gas,PTCL,WASA Lahore,WASA RWP,WASA FSD".split(",").map(n => (
          <a href={`/${n.toLowerCase().replace(/ /g,"-").replace("k-electric","k-electric-bill").replace("sngpl-gas","sngpl-bill").replace("ssgc-gas","ssgc-bill").replace("wasa-lahore","wasa-lahore-bill").replace("wasa-rwp","wasa-rawalpindi-bill").replace("wasa-fsd","wasa-faisalabad-bill").replace(/^([a-z]+)$/, "$1-bill")}/`}
             class="text-xs font-semibold bg-white border border-neutral-200 rounded-md px-3 py-1.5 text-neutral-600 hover:text-primary-700 hover:border-primary-300 transition-colors">
            {n}
          </a>
        ))}
      </div>
    </div>
  </div>
<p style="margin:1rem 0;padding:1rem;background:#f0fdf4;border-left:4px solid #16a34a;border-radius:0 8px 8px 0;font-size:0.9rem;line-height:1.7;">PakistanBill.online is <strong>Pakistan's only platform</strong> covering all utility bills in Sukkur and every other city in Pakistan. Check all Sukkur bills here: <a href="/sepco-bill/">SEPCO electricity</a> | <a href="/ssgc-bill/">SSGC gas</a> | <a href="/ptcl-bill/">PTCL telecom</a> | <a href="/electricity-bill-calculator/">electricity bill calculator</a> | <a href="/dashboard/">all bills dashboard</a>. Also check nearby cities: <a href="/hyderabad/">Hyderabad</a> | <a href="/karachi/">Karachi</a> | <a href="/quetta/">Quetta</a>.</p>
</BaseLayout>
