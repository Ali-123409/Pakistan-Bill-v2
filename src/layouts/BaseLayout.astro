---
// BaseLayout.astro — Master layout for all pages
// Handles: SEO, Schema, OG tags, canonical, fonts

interface Props {
  title: string;
  description: string;
  canonical?: string;
  schema?: object | object[];
  ogImage?: string;
  noindex?: boolean;
  lastmod?: string;
  pageType?: 'website' | 'article' | 'tool';
  disco?: string;
}

const {
  title,
  description,
  canonical,
  schema,
  ogImage = '/images/og-default.png',
  noindex = false,
  lastmod,
  pageType = 'website',
  disco,
} = Astro.props;

const canonicalURL = canonical 
  ? `https://pakistanbill.online${canonical}`
  : Astro.url.href;

// Organization schema — always present site-wide
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://pakistanbill.online/#organization",
  "name": "PakistanBill",
  "url": "https://pakistanbill.online",
  "logo": {
    "@type": "ImageObject",
    "url": "https://pakistanbill.online/images/logo.png",
    "width": 200,
    "height": 60
  },
  "description": "Pakistan's only all-in-one utility bill platform. Check every electricity, gas, water and telecom bill — all 19 providers — in one place. LESCO, MEPCO, GEPCO, K-Electric, SNGPL, SSGC, PTCL. Free, instant, no login.",
  "areaServed": "Pakistan",
  "knowsAbout": ["Pakistan Electricity Bills", "LESCO Bill", "MEPCO Bill", "GEPCO Bill", "FESCO Bill", "IESCO Bill", "PESCO Bill", "HESCO Bill", "SEPCO Bill", "QESCO Bill", "TESCO Bill", "AJK Bill", "K-Electric Bill", "SNGPL Gas Bill", "SSGC Gas Bill", "PTCL Bill", "WASA Water Bill", "Pakistan Utility Bills", "NEPRA Tariff", "Electricity Bill Calculator"],
  "sameAs": [
    "https://www.facebook.com/pakistanbill",
    "https://www.youtube.com/@pakistanbill"
  ]
};

// WebSite schema with Sitelinks Searchbox
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://pakistanbill.online/#website",
  "name": "PakistanBill",
  "url": "https://pakistanbill.online",
  "publisher": { "@id": "https://pakistanbill.online/#organization" },
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://pakistanbill.online/search?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
};

// Combine all schemas
const allSchemas = [orgSchema, websiteSchema];
if (schema) {
  if (Array.isArray(schema)) {
    allSchemas.push(...schema);
  } else {
    allSchemas.push(schema);
  }
}

const currentYear = new Date().getFullYear();
const currentMonth = new Date().toLocaleString('en-US', { month: 'long' });
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- Primary SEO Tags -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="alternate" hreflang="en-PK" href={canonicalURL} />
  <link rel="alternate" hreflang="en" href={canonicalURL} />
  <link rel="alternate" hreflang="x-default" href={canonicalURL} />

  <!-- Robots -->
  {noindex 
    ? <meta name="robots" content="noindex, nofollow" />
    : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  }

  <!-- Open Graph -->
  <meta property="og:type" content={pageType === 'article' ? 'article' : 'website'} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`https://pakistanbill.online${ogImage}`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="PakistanBill" />
  <meta property="og:locale" content="en_PK" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`https://pakistanbill.online${ogImage}`} />

  <!-- Geo Tags — helps local Pakistan SEO -->
  <meta name="geo.region" content="PK" />
  <meta name="geo.country" content="Pakistan" />
  <meta name="language" content="English" />

  <!-- Last Modified -->
  {lastmod && <meta http-equiv="last-modified" content={lastmod} />}
  <!-- Freshness signals for Google -->
  {lastmod && <meta property="article:modified_time" content={`${lastmod}T00:00:00+05:00`} />}
  {lastmod && <meta property="article:published_time" content="2026-01-01T00:00:00+05:00" />}
  <meta name="revisit-after" content="7 days" />


  <!-- PWA / Add to Home Screen -->
