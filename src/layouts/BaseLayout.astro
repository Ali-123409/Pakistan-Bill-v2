  <meta name="theme-color" content="#01411C" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />
  <meta name="apple-mobile-web-app-title" content="PakistanBill" />
  <link rel="apple-touch-icon" href="/images/icon-192.png" />
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png" />

  <!-- Sitemaps -->
  <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

  <!-- Fonts — preconnect for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

  <!-- Global Styles -->
  <link rel="stylesheet" href="/styles/global.css" />

  <!-- Schema Markup — JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(allSchemas)} />

  <!-- Google Analytics 4 -->
  <!-- Replace G-XXXXXXXXXX with your GA4 ID after setup -->
  <!--
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
